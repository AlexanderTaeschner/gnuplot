/* Common code to crop the image around its bounding box, just before writing
   down the file.
*/
static void
image_do_crop (void)
{
    if (png_state.flags & PNG_USE_CROP) {
	int x, y, x1, y1, x2, y2, flag;
	int bg = png_state.color_table[0]; /* index of the background color */
	gdImagePtr im_crop;
	for (flag=0, x1=0; x1 < gdImageSX(png_state.image)-1; x1++) {
	    for (y=0; y < gdImageSY(png_state.image); y++)
		if (gdImageGetPixel(png_state.image, x1, y) != bg) { flag = 1; break; }
	    if (flag) break;
	}
	for (flag=0, x2=gdImageSX(png_state.image)-1; x2 >= x1; x2--) {
	    for (y=0; y < gdImageSY(png_state.image); y++)
		if (gdImageGetPixel(png_state.image, x2, y) != bg) { flag = 1; break; }
	    if (flag) break;
	}
	for (flag=0, y1=0; y1 < gdImageSY(png_state.image)-1; y1++) {
	    for (x=x1; x <= x2; x++)
		if (gdImageGetPixel(png_state.image, x, y1) != bg) { flag = 1; break; };
	    if (flag) break;
	}
	for (flag=0, y2=gdImageSY(png_state.image)-1; y2 >= y1; y2--) {
	    for (x=x1; x <= x2; x++)
		if (gdImageGetPixel(png_state.image, x, y2) != bg) { flag = 1; break; };
	    if (flag) break;
	}
	x = x2 - x1 + 1; /* width */
	y = y2 - y1 + 1; /* height */

	if (png_state.TrueColor)
	    im_crop = gdImageCreateTrueColor(x,y);
	else
	    im_crop = gdImageCreate(x,y);
	if (!im_crop) {
	    int_warn(NO_CARET,"libgd: failed to create cropped image structure");
	    return;
	}
	bg = gdImageColorAllocateAlpha(im_crop,255,255,255,127);

	/* FIXME: getting black background for truecolor & transparent */
	gdImagePaletteCopy(im_crop, png_state.image);
	if (png_state.flags & PNG_USE_TRANSPARENT) {
	    gdImageColorTransparent(im_crop, bg);
	    /* WARNING: This is a work-around for strangeness in libgd,  */
	    /* which doesn't copy transparent pixels in TrueColor images. */
	    if (png_state.TrueColor)
		gdImageColorTransparent(png_state.image, -1);
	} else
	    gdImageColorTransparent(im_crop, -1);

	gdImageCopy(im_crop, png_state.image, 0, 0, x1, y1, x, y);
	gdImageDestroy(png_state.image);
	png_state.image = im_crop;
	/* Re-set transparency for sixelgd */
	if (strcmp("sixelgd", term->name) == 0 &&
	    png_state.TrueColor && (png_state.flags & PNG_USE_TRANSPARENT)) {
	    gdImageColorTransparent(png_state.image, png_state.color_table[0]);
	}
    }
}


static int PNG_FillSolid(int fillpar);
static int PNG_FillPattern(int fillpar);
static int PNG_FillTransparent(int fillpar);

static int
PNG_FillSolid(int fillpar)
{
    int red   = (png_state.rgb >> 16) & 0xff;
    int green = (png_state.rgb >> 8) & 0xff;
    int blue  = png_state.rgb & 0xff;

    double fact = (double)(100 - fillpar) * 0.01;

    int color;

    if (fact <= 0 || fact >= 1.0)
	return png_state.color;

    red   += (0xff - red) * fact;
    green += (0xff - green) * fact;
    blue  += (0xff - blue) * fact;

    color = gdImageColorExact(png_state.image, red, green, blue);
    if (color < 0) {
	color = gdImageColorAllocate(png_state.image, red, green, blue);
    }
    if (color < 0) {
	color = gdImageColorClosest(png_state.image, red, green, blue);
    }

    return color;
}

static int
PNG_FillTransparent(int fillpar)
{
    int red   = (png_state.rgb >> 16) & 0xff;
    int green = (png_state.rgb >> 8) & 0xff;
    int blue  = png_state.rgb & 0xff;
    int alpha = 127 * (double)(100-fillpar) / 100.;

    return  gdImageColorExactAlpha(png_state.image, red, green, blue, alpha);
}

static int
PNG_FillPattern(int style)
{
    int rgb = png_state.rgb;
    int brgb = png_state.rgb_table[0];
    int fillpar = (style >> 4) % 8;
    style = style & 0xf;

    if (!PNG_fill_tile.im || rgb != PNG_fill_tile.last_rgb || PNG_fill_tile.fillpar != fillpar) {

	int foreground, background;

	if (PNG_fill_tile.im) {
	    gdImageDestroy(PNG_fill_tile.im);
	    PNG_fill_tile.im = (gdImagePtr)0;
	}

	/* save new values */
	PNG_fill_tile.fillpar = fillpar;
	PNG_fill_tile.last_rgb = rgb;

	/* create new tile */
	if (!((PNG_fill_tile.im = gdImageCreate(8, 8))))
	    int_error(NO_CARET,"libgd: failed to create pattern-fill tile");

	background = gdImageColorAllocate(PNG_fill_tile.im,
		(brgb >> 16) & 0xff, (brgb >> 8) & 0xff, brgb & 0xff);
	if (style == FS_TRANSPARENT_PATTERN)
	    gdImageColorTransparent(PNG_fill_tile.im, background);
	gdImageFilledRectangle(PNG_fill_tile.im, 0, 0, 7, 7, background);

	/* foreground */
	foreground = gdImageColorAllocate(PNG_fill_tile.im,
		(rgb >> 16) & 0xff, (rgb >> 8) & 0xff, rgb & 0xff);

	switch (fillpar) {
	    case 0: /* no fill */
	    default:
		break;
	    case 1: /* cross-hatch */
		gdImageLine(PNG_fill_tile.im, 0, 0, 7, 7, foreground);
		gdImageLine(PNG_fill_tile.im, 0, 6, 6, 0, foreground);
		break;
	    case 2: /* double cross-hatch */
		gdImageLine(PNG_fill_tile.im, 0, 0, 7, 7, foreground);
		gdImageLine(PNG_fill_tile.im, 0, 6, 6, 0, foreground);
		gdImageLine(PNG_fill_tile.im, 0, 2, 2, 0, foreground);
		gdImageLine(PNG_fill_tile.im, 7, 3, 3, 7, foreground);
		gdImageLine(PNG_fill_tile.im, 4, 0, 7, 3, foreground);
		gdImageLine(PNG_fill_tile.im, 0, 4, 3, 7, foreground);
		break;
	    case 3: /* solid */
		gdImageFilledRectangle(PNG_fill_tile.im, 0, 0, 7, 7, foreground);
		break;
	    case 4:
		gdImageLine(PNG_fill_tile.im, 0, 0, 7, 7, foreground);
		break;
	    case 5:
		gdImageLine(PNG_fill_tile.im, 0, 7, 7, 0, foreground);
		break;
	    case 6:
		gdImageLine(PNG_fill_tile.im, 0, 0, 3, 7, foreground);
		gdImageLine(PNG_fill_tile.im, 4, 0, 7, 7, foreground);
		break;
	    case 7:
		gdImageLine(PNG_fill_tile.im, 0, 7, 3, 0, foreground);
		gdImageLine(PNG_fill_tile.im, 4, 7, 7, 0, foreground);
		break;
	    case 8:
		gdImageLine(PNG_fill_tile.im, 0, 0, 7, 3, foreground);
		gdImageLine(PNG_fill_tile.im, 0, 4, 7, 7, foreground);
		break;
	    case 9:
		gdImageLine(PNG_fill_tile.im, 0, 3, 7, 0, foreground);
		gdImageLine(PNG_fill_tile.im, 0, 7, 7, 4, foreground);
		break;
	}
    }

    gdImageSetTile(png_state.image, PNG_fill_tile.im);
    return (int)gdTiled;
}

/*
 * PNG_BLEND_COLOR - fixed-point alpha blend matching libgd's convention.
 * a = blending factor (0=fully opaque, 255=fully transparent for the dest),
 * nc = output, c = background, cc = foreground.
 */
#define PNG_BLEND_COLOR(a, nc, c, cc) \
    nc = (cc) + (((((c) - (cc)) * (a)) + ((((c) - (cc)) * (a)) >> 8) + 0x80) >> 8)

/*
 * Alpha layer management for overlap-free semi-transparent line rendering.
 *
 * When line color has alpha > 0 (libgd convention: 0=opaque, 127=transparent),
 * drawing overlapping sub-segments directly causes visible striping because
 * each overlap region gets blended multiple times.
 *
 * Solution: redirect drawing to an offscreen buffer at full opacity, using
 * MAX-compositing (most-opaque-wins) so overlaps keep the highest coverage.
 * When the polyline path ends, composite the buffer onto the main image
 * with the line's target alpha.
 */

/* Activate the alpha layer: lazy-create buffer, swap png_state.image. */
static void
PNG_alpha_layer_begin(int color)
{
    int cx1, cy1, cx2, cy2;

    if (!png_state.alpha_layer) {
	int sx = gdImageSX(png_state.image);
	int sy = gdImageSY(png_state.image);
	png_state.alpha_layer = gdImageCreateTrueColor(sx, sy);
	if (!png_state.alpha_layer)
	    return;
	gdImageAlphaBlending(png_state.alpha_layer, gdEffectReplace);
	gdImageSaveAlpha(png_state.alpha_layer, 1);
	gdImageFilledRectangle(png_state.alpha_layer, 0, 0, sx - 1, sy - 1,
			       gdTrueColorAlpha(0, 0, 0, gdAlphaTransparent));
    }

    /* Copy current clip region to alpha layer */
    gdImageGetClip(png_state.image, &cx1, &cy1, &cx2, &cy2);

    png_state.alpha_main_image = png_state.image;
    png_state.image = png_state.alpha_layer;
    gdImageSetClip(png_state.image, cx1, cy1, cx2, cy2);

    png_state.alpha_line_gd_alpha = gdTrueColorGetAlpha(color);
    png_state.alpha_opaque_color = gdTrueColorAlpha(
	gdTrueColorGetRed(color), gdTrueColorGetGreen(color),
	gdTrueColorGetBlue(color), gdAlphaOpaque);

    /* Init dirty rect to empty (use image bounds as sentinel) */
    {
	int sx = gdImageSX(png_state.image);
	int sy = gdImageSY(png_state.image);
	png_state.alpha_dirty_x1 = sx;
	png_state.alpha_dirty_y1 = sy;
	png_state.alpha_dirty_x2 = -1;
	png_state.alpha_dirty_y2 = -1;
    }
    png_state.alpha_layer_active = TRUE;
}

/* Composite the alpha layer onto the main image, clear dirty region, restore. */
static void
PNG_alpha_layer_composite(void)
{
    int x, y;
    int line_alpha = png_state.alpha_line_gd_alpha;
    double line_opacity = 1.0 - (double)line_alpha / 127.0;
    gdImagePtr main_img = png_state.alpha_main_image;
    gdImagePtr buf = png_state.alpha_layer;

    /* Restore image pointer */
    png_state.image = main_img;
    png_state.alpha_layer_active = FALSE;

    if (png_state.alpha_dirty_x1 > png_state.alpha_dirty_x2)
	return; /* nothing was drawn */

    for (y = png_state.alpha_dirty_y1; y <= png_state.alpha_dirty_y2; y++) {
	for (x = png_state.alpha_dirty_x1; x <= png_state.alpha_dirty_x2; x++) {
	    int buf_p = gdImageGetTrueColorPixel(buf, x, y);
	    int buf_alpha = gdTrueColorGetAlpha(buf_p);
	    double cov_opacity, eff_opacity;
	    int t, main_p;
	    int dr, dg, db, r, g, b;

	    /* Clear this pixel (gdEffectReplace is set on the buffer) */
	    gdImageSetPixel(buf, x, y,
			    gdTrueColorAlpha(0, 0, 0, gdAlphaTransparent));

	    if (buf_alpha >= gdAlphaTransparent)
		continue; /* was fully transparent, skip */

	    /* Effective opacity = buffer coverage × line alpha */
	    cov_opacity = 1.0 - (double)buf_alpha / 127.0;
	    eff_opacity = cov_opacity * line_opacity;
	    if (eff_opacity <= 0.0)
		continue;

	    t = (int)((1.0 - eff_opacity) * 255.0 + 0.5);

	    /* Blend onto main image */
	    main_p = gdImageGetTrueColorPixel(main_img, x, y);
	    dr = gdTrueColorGetRed(buf_p);   r = gdTrueColorGetRed(main_p);
	    dg = gdTrueColorGetGreen(buf_p); g = gdTrueColorGetGreen(main_p);
	    db = gdTrueColorGetBlue(buf_p);  b = gdTrueColorGetBlue(main_p);
	    PNG_BLEND_COLOR(t, dr, r, dr);
	    PNG_BLEND_COLOR(t, dg, g, dg);
	    PNG_BLEND_COLOR(t, db, b, db);
	    gdImageSetPixel(main_img, x, y,
			    gdTrueColorAlpha(dr, dg, db, gdAlphaOpaque));
	}
    }
}

/* Free the alpha layer buffer. Called after frame output. */
static void
PNG_alpha_layer_destroy(void)
{
    if (png_state.alpha_layer) {
	gdImageDestroy(png_state.alpha_layer);
	png_state.alpha_layer = NULL;
    }
    png_state.alpha_layer_active = FALSE;
}

static void
PNG_SetAAPixelColor(int x, int y, int color, int t)
{
    int dr, dg, db, p, r, g, b;
    int fa;  /* foreground alpha from the color parameter */

    if (!gdImageBoundsSafe(png_state.image, x, y))
	return;

    /* Alpha layer MAX-compositing: write only if more opaque than existing */
    if (png_state.alpha_layer_active) {
	int new_gd_alpha, existing, existing_alpha;
	if (t >= 255)
	    return;
	new_gd_alpha = (t == 0) ? 0 : (int)((double)t * 127.0 / 255.0 + 0.5);
	existing = gdImageGetTrueColorPixel(png_state.image, x, y);
	existing_alpha = gdTrueColorGetAlpha(existing);
	if (new_gd_alpha < existing_alpha) {
	    gdImageSetPixel(png_state.image, x, y,
		gdTrueColorAlpha(gdTrueColorGetRed(color),
				 gdTrueColorGetGreen(color),
				 gdTrueColorGetBlue(color), new_gd_alpha));
	    if (x < png_state.alpha_dirty_x1) png_state.alpha_dirty_x1 = x;
	    if (x > png_state.alpha_dirty_x2) png_state.alpha_dirty_x2 = x;
	    if (y < png_state.alpha_dirty_y1) png_state.alpha_dirty_y1 = y;
	    if (y > png_state.alpha_dirty_y2) png_state.alpha_dirty_y2 = y;
	}
	return;
    }

    if (!png_state.TrueColor) {
	if (t < 128)
	    gdImageSetPixel(png_state.image, x, y, color);
	return;
    }

    /* Combine coverage-based transparency 't' with foreground alpha.
     * libgd alpha: 0 = opaque, 127 = transparent.
     * 't' from caller: 0 = fully covered, 255 = fully transparent.
     * Effective opacity = coverage_opacity * foreground_opacity.
     */
    fa = gdTrueColorGetAlpha(color);
    if (fa > 0) {
	double fg_opacity = 1.0 - (double)fa / 127.0;
	double cov_opacity = 1.0 - (double)t / 255.0;
	double eff_opacity = fg_opacity * cov_opacity;
	if (eff_opacity <= 0.0)
	    return;
	t = (int)((1.0 - eff_opacity) * 255.0 + 0.5);
    }

    if (t == 0) {
	gdImageSetPixel(png_state.image, x, y,
			gdTrueColorAlpha(gdTrueColorGetRed(color),
					 gdTrueColorGetGreen(color),
					 gdTrueColorGetBlue(color),
					 gdAlphaOpaque));
	return;
    }
    if (t >= 255)
	return;

    p = gdImageGetPixel(png_state.image, x, y);

    dr = gdTrueColorGetRed(color);
    dg = gdTrueColorGetGreen(color);
    db = gdTrueColorGetBlue(color);
    r = gdTrueColorGetRed(p);
    g = gdTrueColorGetGreen(p);
    b = gdTrueColorGetBlue(p);
    PNG_BLEND_COLOR(t, dr, r, dr);
    PNG_BLEND_COLOR(t, dg, g, dg);
    PNG_BLEND_COLOR(t, db, b, db);
    gdImageSetPixel(png_state.image, x, y,
		    gdTrueColorAlpha(dr, dg, db, gdAlphaOpaque));
}

/* Convert our linecap enum to the cap type used for dash endpoints. */
static int
PNG_linecap_to_dashcap(t_linecap lc)
{
    switch (lc) {
	case ROUNDED: return PNG_CAP_ROUND;
	case SQUARE:  return PNG_CAP_SQUARE;
	default:      return PNG_CAP_BUTT;
    }
}

/*
 * PNG_draw_aa_thick_line - Draw one antialiased thick line segment.
 *
 * Uses an analytic signed-distance-field rasterizer that evaluates each
 * pixel in the segment's bounding box.  Supports four endcap modes at
 * each end (PNG_CAP_HARD, _BUTT, _ROUND, _SQUARE).
 *
 * For linewidth 1, delegates to libgd's native gdAntiAliased renderer
 * since endcap detail is invisible at that thickness.
 */
static void
PNG_draw_aa_thick_line(double ax, double ay, double bx, double by,
		       int thick, int color, int cap_start, int cap_end)
{
    double dx = bx - ax;
    double dy = by - ay;
    double len = sqrt(dx * dx + dy * dy);
    double halfw = 0.5 * (double)thick;
    double ux, uy, vx, vy;
    int xmin, xmax, ymin, ymax;
    int x, y;

    /* Thin solid lines: use libgd native line drawing for performance.
     * Dashed thin lines always use the SDF rasterizer below, which handles
     * sub-pixel dash/gap boundaries correctly.
     */
    if (thick <= 1 && png_state.dashtype == DASHTYPE_SOLID) {
	gdImageSetAntiAliased(png_state.image, color);
	gdImageSetThickness(png_state.image, 1);
	gdImageLine(png_state.image,
		    (int)(ax + 0.5), (int)(ay + 0.5),
		    (int)(bx + 0.5), (int)(by + 0.5),
		    gdAntiAliased);
	return;
    }

    /* Degenerate segment: just draw round-cap dot if applicable */
    if (len < 0.01) {
	if (cap_start == PNG_CAP_ROUND || cap_end == PNG_CAP_ROUND) {
	    int xi, yi;
	    int r = (int)(halfw + 1.5);
	    int cxi = (int)(ax + 0.5), cyi = (int)(ay + 0.5);
	    for (yi = cyi - r; yi <= cyi + r; yi++)
		for (xi = cxi - r; xi <= cxi + r; xi++) {
		    double ddx = xi + 0.5 - ax;
		    double ddy = yi + 0.5 - ay;
		    double dist = sqrt(ddx*ddx + ddy*ddy) - halfw;
		    double cov = 0.5 - dist;
		    if (cov <= 0.0) continue;
		    if (cov >= 1.0)
			gdImageSetPixel(png_state.image, xi, yi, color);
		    else
			PNG_SetAAPixelColor(xi, yi, color,
					    (int)((1.0 - cov) * 255.0 + 0.5));
		}
	}
	return;
    }

    /* Unit vectors: along line, perpendicular to line */
    ux = dx / len;  uy = dy / len;
    vx = -uy;       vy = ux;

    /* Bounding box with padding for caps */
    {
	double pad_s = halfw + 1.0;
	double pad_e = halfw + 1.0;
	double ex0, ex1, ey0, ey1;

	if (cap_start == PNG_CAP_SQUARE) pad_s += halfw;
	if (cap_start == PNG_CAP_ROUND)  pad_s += 0.5;
	if (cap_end == PNG_CAP_SQUARE)   pad_e += halfw;
	if (cap_end == PNG_CAP_ROUND)    pad_e += 0.5;

	ex0 = ax - ux * pad_s;
	ey0 = ay - uy * pad_s;
	ex1 = bx + ux * pad_e;
	ey1 = by + uy * pad_e;

	xmin = (int)floor(fmin(fmin(ex0, ex1), fmin(ax, bx)) - halfw - 1.0);
	xmax = (int)ceil (fmax(fmax(ex0, ex1), fmax(ax, bx)) + halfw + 1.0);
	ymin = (int)floor(fmin(fmin(ey0, ey1), fmin(ay, by)) - halfw - 1.0);
	ymax = (int)ceil (fmax(fmax(ey0, ey1), fmax(ay, by)) + halfw + 1.0);
    }

    /* Clamp iteration bounds to the current libgd clip rectangle.
     * PNG_SetAAPixelColor already rejects out-of-clip pixels via
     * gdImageBoundsSafe; this avoids the wasted SDF evaluation for
     * those pixels and provides an early-out for fully clipped segments.
     */
    {
	int cx1, cy1, cx2, cy2;
	gdImageGetClip(png_state.image, &cx1, &cy1, &cx2, &cy2);
	if (xmin < cx1) xmin = cx1;
	if (xmax > cx2) xmax = cx2;
	if (ymin < cy1) ymin = cy1;
	if (ymax > cy2) ymax = cy2;
	if (xmin > xmax || ymin > ymax)
	    return;
    }

    for (y = ymin; y <= ymax; y++) {
	for (x = xmin; x <= xmax; x++) {
	    double px = x + 0.5;
	    double py = y + 0.5;
	    double rx = px - ax;
	    double ry = py - ay;
	    double a = rx * ux + ry * uy;	/* along line */
	    double b = rx * vx + ry * vy;	/* perpendicular (signed) */
	    double absb = fabs(b);
	    double sdf;

	    /* === Round cap regions === */
	    if (cap_start == PNG_CAP_ROUND && a < 0.0) {
		sdf = sqrt(a * a + b * b) - halfw;
		goto aa_pixel;
	    }
	    if (cap_end == PNG_CAP_ROUND && a > len) {
		double da = a - len;
		sdf = sqrt(da * da + b * b) - halfw;
		goto aa_pixel;
	    }

	    /* === Hard-clip rejection === */
	    if (cap_start == PNG_CAP_HARD && a < -0.5)
		continue;
	    if (cap_end == PNG_CAP_HARD && a > len + 0.5)
		continue;

	    /* === Rectangular SDF === */
	    {
		double d_perp = absb - halfw;
		double d_start, d_end;

		switch (cap_start) {
		    case PNG_CAP_BUTT:   d_start = -a;                 break;
		    case PNG_CAP_SQUARE: d_start = -(a + halfw);       break;
		    default:             d_start = -1e30;               break;
		}
		switch (cap_end) {
		    case PNG_CAP_BUTT:   d_end = a - len;              break;
		    case PNG_CAP_SQUARE: d_end = a - (len + halfw);    break;
		    default:             d_end = -1e30;                 break;
		}

		sdf = d_perp;
		if (d_start > sdf) sdf = d_start;
		if (d_end   > sdf) sdf = d_end;
	    }

	aa_pixel:
	    {
		double cov = 0.5 - sdf;
		if (cov <= 0.0)
		    continue;
		if (cov >= 1.0) {
		    PNG_SetAAPixelColor(x, y, color, 0);
		} else {
		    PNG_SetAAPixelColor(x, y, color,
				       (int)((1.0 - cov) * 255.0 + 0.5));
		}
	    }
	}
    }
}

/* Flush the deferred endcap at the last drawn dash segment endpoint. */
static void
PNG_flush_pending_endcap(void)
{
    if (!PNG_pending_endcap.active)
	return;
    if (PNG_pending_endcap.thick > 1) {
	int cap = PNG_linecap_to_dashcap(png_state.linecap);
	double eps = 0.5;
	double ax = PNG_pending_endcap.ex - eps * PNG_pending_endcap.ux;
	double ay = PNG_pending_endcap.ey - eps * PNG_pending_endcap.uy;

	PNG_draw_aa_thick_line(ax, ay,
			       PNG_pending_endcap.ex, PNG_pending_endcap.ey,
			       PNG_pending_endcap.thick,
			       PNG_pending_endcap.color,
			       PNG_CAP_HARD, cap);
    }
    PNG_pending_endcap.active = 0;
}

/*
 * PNG_in_drawn_phase - Check if the current dash_pos is in a visible (drawn)
 * phase of the dash pattern.  Returns TRUE if we're in a drawn element
 * (even-indexed element in the pattern array).
 */
static TBOOLEAN
PNG_in_drawn_phase(double dash_pos, float *pattern, double scale)
{
    double scaled_pat[DASHPATTERN_LENGTH];
    double dash_total = 0.0;
    int pat_len = 0;
    int i;
    double pos, accum;

    for (i = 0; pattern[i] > 0.0 && i < DASHPATTERN_LENGTH; i++) {
	scaled_pat[i] = pattern[i] * scale;
	if (scaled_pat[i] < 1.0) scaled_pat[i] = 1.0;
	dash_total += scaled_pat[i];
	pat_len++;
    }
    if (pat_len == 0 || dash_total <= 0.0)
	return TRUE;  /* solid line */

    pos = fmod(dash_pos, dash_total);
    if (pos < 0.0) pos += dash_total;

    accum = 0.0;
    for (i = 0; i < pat_len - 1; i++) {
	if (pos < accum + scaled_pat[i])
	    break;
	accum += scaled_pat[i];
    }
    return (i % 2) == 0;
}

/*
 * PNG_draw_join_disc - Draw an AA round join disc at junction point (cx, cy)
 * between two segments with normalized directions (px, py) and (nx, ny).
 * For ROUNDED endcaps: full disc (always correct).
 * For BUTT/SQUARE endcaps: disc clipped by SDF half-planes so it
 * doesn't protrude beyond the flat dash edges.
 * Pixel-float coordinates.
 */
static void
PNG_draw_join_disc(double cx, double cy, double radius,
                   double px, double py,   /* prev segment direction (normalized) */
                   double nx, double ny,   /* next segment direction (normalized) */
                   int color)
{
    int ix_min = (int)floor(cx - radius - 1.0);
    int ix_max = (int)ceil(cx + radius + 1.0);
    int iy_min = (int)floor(cy - radius - 1.0);
    int iy_max = (int)ceil(cy + radius + 1.0);
    int ix, iy;

    for (iy = iy_min; iy <= iy_max; iy++) {
        for (ix = ix_min; ix <= ix_max; ix++) {
            double dx = (double)ix + 0.5 - cx;
            double dy = (double)iy + 0.5 - cy;

            /* SDF: distance from disc boundary (positive = inside) */
            double dist_disc = radius - sqrt(dx*dx + dy*dy);

            if (png_state.linecap != ROUNDED) {
                /* For butt/square caps, only draw disc pixels that fall
                 * in the gap region between the two rectangle ends.
                 * A pixel is past the prev rect's end face if:
                 *   dot(pixel, prev_dir) > 0
                 * A pixel is before the next rect's start face if:
                 *   dot(pixel, next_dir) < 0
                 * The gap region on the convex side satisfies both.
                 */
                double past_prev =  (dx * px + dy * py);
                double before_next = -(dx * nx + dy * ny);
                double in_gap = GPMIN(past_prev, before_next);
                dist_disc = GPMIN(dist_disc, in_gap);
            }

            {
                double cov = dist_disc + 0.5;
                if (cov <= 0.0)
                    continue;
                if (cov >= 1.0) {
                    PNG_SetAAPixelColor(ix, iy, color, 0);
                } else {
                    PNG_SetAAPixelColor(ix, iy, color,
                                       (int)((1.0 - cov) * 255.0 + 0.5));
                }
            }
        }
    }
}

/*
 * PNG_draw_aa_vector - Draw an antialiased thick vector segment with
 * join-disc and deferred-endcap handling.
 *
 * When pattern is NULL, draws a solid segment.
 * When pattern is non-NULL, walks the dash pattern along the segment,
 * drawing each visible (dash-on) portion as an AA thick-line sub-segment.
 *
 * Endcaps are applied at path endpoints and at dash boundaries (on→off
 * or off→on transitions).  At internal polyline joints where the stroke
 * continues to the next vector call, segments are joined with HARD caps
 * and a small overlap so that no seam (zebra stripe) is visible.
 *
 * The global PNG_dash_pos tracks the position in the dash cycle across
 * successive calls, so dashes follow the polyline curve faithfully.
 *
 * Coordinates are in pixel-float space (from GD_PXF/GD_YF).
 */
static void
PNG_draw_aa_vector(double x1, double y1, double x2, double y2,
		   float *pattern, double scale, int thick, int color)
{
    double dx = x2 - x1;
    double dy = y2 - y1;
    double seg_len = sqrt(dx * dx + dy * dy);
    int user_cap = PNG_linecap_to_dashcap(png_state.linecap);
    double seg_nx, seg_ny;  /* normalized direction of this segment */

    if (seg_len <= 0.001)
	return;

    seg_nx = dx / seg_len;
    seg_ny = dy / seg_len;

    /* Check if we need a join disc at the start of this segment.
     * For solid lines, always draw if the angle exceeds the threshold.
     * For dashed lines, only draw if currently in a drawn phase.
     */
    {
	double prev_len = sqrt(PNG_prev_dash_dx*PNG_prev_dash_dx
			     + PNG_prev_dash_dy*PNG_prev_dash_dy);
	if (prev_len > 0.0) {
	    double pnx = PNG_prev_dash_dx / prev_len;
	    double pny = PNG_prev_dash_dy / prev_len;
	    double dot = pnx * seg_nx + pny * seg_ny;
	    double cross = pnx * seg_ny - pny * seg_nx;  /* sin(turn angle) */

	    if ((0.0 < (1.0 + dot)) && ((1.0 + dot) < fabs(cross) * thick)) {
		TBOOLEAN in_drawn = pattern
		    ? (PNG_dash_pos > 0.0
		       && PNG_in_drawn_phase(PNG_dash_pos, pattern, scale))
		    : TRUE;
		if (in_drawn) {
		    PNG_draw_join_disc(x1, y1, thick / 2.0,
				       pnx, pny, seg_nx, seg_ny,
				       color);
		}
	    }
	}
    }

    if (pattern == NULL) {
	/* === Solid segment === */
	int cs, ce;

	/* First segment after PNG_move: use user's linecap at start */
	if (PNG_prev_dash_dx == 0.0 && PNG_prev_dash_dy == 0.0) {
	    cs = user_cap;
	    PNG_flush_pending_endcap();
	} else {
	    /* Internal joint: HARD start cap */
	    cs = PNG_CAP_HARD;
	    PNG_pending_endcap.active = 0;
	}

	/* End: always HARD (deferred until next PNG_move confirms path end) */
	ce = PNG_CAP_HARD;
	PNG_pending_endcap.active = 1;
	PNG_pending_endcap.ex = x2;
	PNG_pending_endcap.ey = y2;
	PNG_pending_endcap.ux = seg_nx;
	PNG_pending_endcap.uy = seg_ny;
	PNG_pending_endcap.thick = thick;
	PNG_pending_endcap.color = color;

	PNG_draw_aa_thick_line(x1, y1, x2, y2, thick, color, cs, ce);

    } else {
	/* === Dashed segment: walk pattern === */
	double scaled_pat[DASHPATTERN_LENGTH];
	double dash_total = 0.0;
	int pat_len = 0;
	int i;
	double s;	/* distance walked along this segment */

	/* DASH_EPSILON is the Minimum meaningful step size in dash walker,
	 * used to guard against infinite-loops at gap-dash boundaries when
	 * the step size is tiny.
	 */
	const double DASH_EPSILON = 0.001;
	const double DASH_BOUNDARY_TOL = 0.01; /* Must be larger than DASH_EPSILON */

	/* Build scaled pattern and total cycle length */
	for (i = 0; pattern[i] > 0.0 && i < DASHPATTERN_LENGTH; i++) {
	    scaled_pat[i] = pattern[i] * scale;
	    if (scaled_pat[i] < 1.0) scaled_pat[i] = 1.0;
	    dash_total += scaled_pat[i];
	    pat_len++;
	}
	if (pat_len == 0 || dash_total <= 0.0) {
	    /* Degenerate: draw solid */
	    PNG_draw_aa_thick_line(x1, y1, x2, y2, thick, color,
				   PNG_CAP_BUTT, PNG_CAP_BUTT);
	    goto done;
	}

	/* Walk the dash pattern along this polyline segment */
	s = 0.0;
	while (s < seg_len - DASH_EPSILON) {
	    double pos, accum;
	    int idx;
	    double pos_in_elem, remaining, step;
	    TBOOLEAN at_element_start, at_element_end;

	    /* Current position within one pattern cycle */
	    pos = fmod(PNG_dash_pos, dash_total);
	    if (pos < 0.0) pos += dash_total;

	    /* Find which pattern element we are in */
	    accum = 0.0;
	    for (idx = 0; idx < pat_len - 1; idx++) {
		if (pos < accum + scaled_pat[idx])
		    break;
		accum += scaled_pat[idx];
	    }
	    pos_in_elem = pos - accum;
	    remaining = scaled_pat[idx] - pos_in_elem;

	    /* Distance to advance: min of remaining-in-element, remaining-in-segment */
	    step = remaining;
	    if (step > seg_len - s)
		step = seg_len - s;

	    /* Guard against floating-point stall at dash-gap boundaries. A stall will otherwise
	     * happen if step is too small to advance PNG_dash_pos to the next possible value.
	     */
	    if (step < DASH_EPSILON) {
		double next_boundary = accum + scaled_pat[idx];
		/* Advance PNG_dash_pos to be safely within the next element */
		PNG_dash_pos = PNG_dash_pos - pos + next_boundary + DASH_EPSILON;
		continue;
	    }

	    /* Detect if we are at the start/end of the current pattern element */
	    at_element_start = (pos_in_elem < DASH_BOUNDARY_TOL);
	    at_element_end   = (remaining - step < DASH_BOUNDARY_TOL);

	    if ((idx % 2) == 0) {
		/* === DASH (on) segment === */
		double t1 = s / seg_len;
		double t2 = (s + step) / seg_len;
		double sx = x1 + dx * t1;
		double sy = y1 + dy * t1;
		double ex = x1 + dx * t2;
		double ey = y1 + dy * t2;
		int cs, ce;

		/* If we had a pending endcap from a previous vector, the
		 * dash continues here.  Flush the pending endcap because
		 * we will now draw this sub-segment with HARD start cap
		 * that overlaps seamlessly.
		 */
		if (at_element_start) {
		    PNG_flush_pending_endcap();
		    cs = user_cap;
		} else {
		    /* Continuation from previous vector: HARD join */
		    PNG_pending_endcap.active = 0;
		    cs = PNG_CAP_HARD;
		}

		if (at_element_end) {
		    ce = user_cap;
		    PNG_pending_endcap.active = 0;
		} else {
		    /* Dash continues past this vector segment */
		    ce = PNG_CAP_HARD;
		    /* Record pending endcap state */
		    PNG_pending_endcap.active = 1;
		    PNG_pending_endcap.ex = ex;
		    PNG_pending_endcap.ey = ey;
		    PNG_pending_endcap.ux = dx / seg_len;
		    PNG_pending_endcap.uy = dy / seg_len;
		    PNG_pending_endcap.thick = thick;
		    PNG_pending_endcap.color = color;
		}

#ifdef GD_DEBUG_DASHES
		{
		    static int dbg_toggle = 0;
		    int dbg_color = (dbg_toggle++ % 2)
			? gdTrueColorAlpha(255, 0, 0, 64)
			: gdTrueColorAlpha(0, 0, 255, 64);
		    PNG_draw_aa_thick_line(sx, sy, ex, ey, thick, dbg_color, cs, ce);
		}
#else
		PNG_draw_aa_thick_line(sx, sy, ex, ey, thick, color, cs, ce);
#endif

	    } else {
		/* === GAP (off) segment === */
		/* If a dash just ended, there is no pending endcap because
		 * the previous dash sub-segment already had proper end cap.
		 * If there's a pending endcap from mid-dash, flush it now
		 * because we're transitioning into a gap.
		 */
		if (at_element_start && PNG_pending_endcap.active)
		    PNG_flush_pending_endcap();
	    }

	    s += step;
	    PNG_dash_pos += step;
	}
    }

done:
    /* Save current direction for next segment's join disc logic */
    PNG_prev_dash_dx = dx;
    PNG_prev_dash_dy = dy;

    /* For closed paths, save the first segment's pixel-space direction
     * and start position (x1,y1 is the path start in pixel coords).
     */
    if (PNG_path_is_open
    &&  PNG_path_first_dx == 0.0 && PNG_path_first_dy == 0.0) {
	PNG_path_first_dx = dx;
	PNG_path_first_dy = dy;
	PNG_path_start_x = x1;
	PNG_path_start_y = y1;
    }
}

static void
PNG_PointX(unsigned int x, unsigned int y)
{
    gdImageLine(png_state.image, x - PNG_ps, y - PNG_ps,
	    x + PNG_ps, y + PNG_ps, png_state.color);
    gdImageLine(png_state.image, x + PNG_ps, y - PNG_ps,
	    x - PNG_ps, y + PNG_ps, png_state.color);
}

static void
PNG_PointPlus(unsigned int x, unsigned int y)
{
    gdImageLine(png_state.image, x - PNG_ps, y,
	    x + PNG_ps, y, png_state.color);
    gdImageLine(png_state.image, x, y - PNG_ps,
	    x, y + PNG_ps, png_state.color);
}

static void
PNG_Triangle(
    unsigned int x, unsigned int y,
    int direction,
    void (*draw_func)(gdImagePtr, gdPointPtr, int, int))
{
    int delta  = (int)((1.33 * (double)PNG_ps) + 0.5);
    int delta_ = (int)((0.67 * (double)PNG_ps) + 0.5);

    gdPoint points[4];
    points[0].x = x;
    points[0].y = y - direction * delta;
    points[1].x = x - delta;
    points[1].y = y + direction * delta_;
    points[2].x = x + delta;
    points[2].y = y + direction * delta_;
    points[3].x = points[0].x;
    points[3].y = points[0].y;
    draw_func(png_state.image, points, 4, png_state.color);
}

static void
PNG_Diamond(
    unsigned int x, unsigned int y,
    void (*draw_func)(gdImagePtr, gdPointPtr, int, int))
{
    gdPoint points[5];
    points[0].x = x;
    points[0].y = y - PNG_ps;
    points[1].x = x + PNG_ps;
    points[1].y = y;
    points[2].x = x;
    points[2].y = y + PNG_ps;
    points[3].x = x - PNG_ps;
    points[3].y = y;
    points[4].x = points[0].x;
    points[4].y = points[0].y;
    draw_func(png_state.image, points, 5, png_state.color);
}

/*
 * _options()  Called when terminal type is selected.
 * This procedure should parse options on the command line.  A list of the
 * currently selected options should be stored in term_options[] in a form
 * suitable for use with the set term command.  term_options[] is used by
 * the save command.  Use options_null() if no options are available.
 */
TERM_PUBLIC void
PNG_options()
{
    double tmp;
    char *string;
    unsigned long color;
    TBOOLEAN gif_anim_option = FALSE; /* set to TRUE if an animated gif option given */

    if (PNG_initialized != term->name) {
	PNG_initialized = term->name;
	term_options[0] = '\0';
	term->h_char = PNG_HCHAR; /* Default to medium font */
	png_state.default_font = gdfont;
	png_state.n_colors = 0;
	png_state.flags = 0;
	png_state.use_builtin = FALSE;
	png_state.ttffont = NULL;
	png_state.default_ttffont = NULL;
	png_state.default_ttfsize = 0;
	png_state.fontscale = 1;
	png_state.justify = CENTRE;
	PNG_linewidth_factor = 1.0;
	PNG_dashlength_factor = 1.0;
	png_state.linecap = BUTT; /* Change Jan 2023 */
	if (!strcmp(term->name, "gif") || !strcmp(term->name, "sixelgd"))
	    png_state.TrueColor = FALSE;
	else
	    png_state.TrueColor = TRUE;
#ifdef _WIN32
	/* Set the default search path for fonts to something useful. */
	if (getenv("GDFONTPATH") == NULL) {
	    const char fonts[] = "\\fonts";
	    char *windir = getenv("windir");
	    if (windir) {
		char *gdfontpath = (char *)
		    gp_alloc(strlen(windir) + strlen(fonts) + 1, "GDFONTPATH");
		if (gdfontpath) {
		   strcpy(gdfontpath, windir);
		   strcat(gdfontpath, fonts);
		   SetEnvironmentVariableA("GDFONTPATH", gdfontpath);
		   free(gdfontpath);
		}
	    }
	}
#endif
    } else {
	if (!png_state.default_font) {
	    int_warn(NO_CARET, "gd.trm: caught initialization error");
	    png_state.default_font = gdfont;
	}
    }

    /* Annoying hack to handle the case of 'set termoption' after */
    /* we are already in animation mode.                          */
    if (almost_equals(c_token-1, "termopt$ion"))
	FPRINTF((stderr,"gif: Maintaining animation state\n"));
    else {
	/* Otherwise reset animation parameters */
	if (png_state.previous_image)
	    gdImageDestroy(png_state.previous_image);
	png_state.animate = FALSE;
	png_state.previous_image = NULL;
	png_state.loop_count = 0;
	/* And default font size */
	term->h_char = PNG_HCHAR;
	png_state.default_ttfsize = 0;
	PNG_linewidth_factor = 1.0;
	PNG_dashlength_factor = 1.0;
	/* Default to enhanced text */
	term->flags |= TERM_ENHANCED_TEXT;
	term->put_text = ENHGD_put_text;
    }

    /* Default to full terminal width; leave 1/4 height underneath for commands */
    if ((strcmp(term->name, "kittygd") == 0)
    ||  (strcmp(term->name, "sixelgd") == 0)) {
	int xpixels, ypixels;
	term_get_termsize( &xpixels, &ypixels );
	if (xpixels > 0 && ypixels > 0) {
	    PNG_XMAX = xpixels;
	    PNG_YMAX = ypixels * 0.75;
	    term->xmax = PNG_XMAX * GD_OVERSAMPLE;
	    term->ymax = PNG_YMAX * GD_OVERSAMPLE;
	    term->h_tic = term->v_tic = 10 * GD_OVERSAMPLE;
	}
    }

    while (!END_OF_COMMAND) {
	switch(lookup_table(&PNG_opts[0],c_token)) {
	case PNG_TRANSPARENT:
	    png_state.flags |= PNG_USE_TRANSPARENT;
	    ++c_token;
	    break;
	case PNG_NOTRANSPARENT:
	    png_state.flags &= ~PNG_USE_TRANSPARENT;
	    ++c_token;
	    break;
	case PNG_INTERLACE:
	    png_state.flags |= PNG_USE_INTERLACE;
	    ++c_token;
	    break;
	case PNG_NOINTERLACE:
	    png_state.flags &= ~PNG_USE_INTERLACE;
	    ++c_token;
	    break;
	case PNG_CROP:
	    png_state.flags |= PNG_USE_CROP;
	    ++c_token;
	    break;
	case PNG_NOCROP:
	    png_state.flags &= ~PNG_USE_CROP;
	    ++c_token;
	    break;

#ifdef HAVE_GD_TTF
# define UNSET_TTF_FONT \
	    free(png_state.ttffont); \
	    png_state.ttffont = NULL; \
	    png_state.default_ttfsize = 2 * term->h_char - 2; \
	    term->h_char *= GD_OVERSAMPLE; \
	    term->v_char *= GD_OVERSAMPLE; \
	    png_state.use_builtin = TRUE;
#else
# define UNSET_TTF_FONT \
	    term->h_char *= GD_OVERSAMPLE; \
	    term->v_char *= GD_OVERSAMPLE;
#endif

	case PNG_TINY:
	    png_state.default_font = gdFontGetTiny();
	    term->v_char = png_state.default_font->h;
	    term->h_char = png_state.default_font->w;
	    ++c_token;
	    UNSET_TTF_FONT;
	    break;
	case PNG_SMALL:
	    png_state.default_font = gdFontGetSmall();
	    term->v_char = png_state.default_font->h;
	    term->h_char = png_state.default_font->w;
	    ++c_token;
	    UNSET_TTF_FONT;
	    break;
	case PNG_MEDIUM:
	    png_state.default_font = gdFontGetMediumBold();
	    term->v_char = png_state.default_font->h;
	    term->h_char = png_state.default_font->w;
	    ++c_token;
	    UNSET_TTF_FONT;
	    break;
	case PNG_LARGE:
	    png_state.default_font = gdFontGetLarge();
	    term->v_char = png_state.default_font->h;
	    term->h_char = png_state.default_font->w;
	    ++c_token;
	    UNSET_TTF_FONT;
	    break;
	case PNG_GIANT:
	    png_state.default_font = gdFontGetGiant();
	    term->v_char = png_state.default_font->h;
	    term->h_char = png_state.default_font->w;
	    ++c_token;
	    UNSET_TTF_FONT;
	    break;

	case PNG_FONT:
	    c_token++;
#ifdef HAVE_GD_TTF
	    if (END_OF_COMMAND) {
		free(png_state.ttffont);
		png_state.ttffont = NULL;
		png_state.default_ttfsize = 0;
	    } else {
		int brect[8];
		char *err;
		char *s;

		if (isstringvalue(c_token) && (s = try_to_get_string())) {
		    char *comma = strrchr(s,',');
		    double fontsize;
		    if (comma && (1 == sscanf(comma+1,"%lf",&fontsize))) {
			png_state.default_ttfsize = fontsize;
			png_state.ttfsize = png_state.default_ttfsize;
			*comma = '\0';
		    }
		    if (*s) {
			free(png_state.ttffont);
			png_state.ttffont = s;
		    } else {
			continue;
		    }
		} else {
		    free(png_state.ttffont);
		    png_state.ttffont = gp_alloc(token_len(c_token)+1,"new font");
		    copy_str(png_state.ttffont, c_token, token_len(c_token)+1);
		    c_token++;
		}
		free(png_state.default_ttffont);
		png_state.default_ttffont = gp_strdup(png_state.ttffont);

		/* First try the old GDFONTPATH mechanism for locating fonts */
		(void)gdUseFontConfig(0);
		err = gdImageStringFT(NULL, &brect[0], 0,
			png_state.ttffont, png_state.default_ttfsize*png_state.fontscale,
			0.0, 0, 0, "test");

		/* If that didn't work, try again using the fontconfig mechanism */
		if (err && gdUseFontConfig(1)) {
		    err = gdImageStringFT(NULL, &brect[0], 0,
			png_state.ttffont, png_state.default_ttfsize*png_state.fontscale,
			0.0, 0, 0, "test");
		}

		/* If we still haven't found the font, punt to the internal non-TTF default set */
		if (err) {
		    fprintf(stderr, "%s when opening font %s, trying default\n",
				err, png_state.ttffont);
		    free(png_state.ttffont);
		    free(png_state.default_ttffont);
		    png_state.ttffont = NULL;
		    png_state.default_ttffont = NULL;
		}

	    }
#else
	    c_token++;
	    fprintf(stderr,"No TTF font support, using internal non-scalable font\n");
#endif
	    break;
# undef UNSET_TTF_FONT

	case PNG_FONTSCALE:
	    c_token++;
	    png_state.fontscale = END_OF_COMMAND ? 1 : real_expression();
	    if (png_state.fontscale <= 0)
		png_state.fontscale = 1.;
	    break;

	case PNG_SIZE:
	    c_token++;
	    if (END_OF_COMMAND) {
		PNG_XMAX = GREG_XMAX;
		PNG_YMAX = GREG_YMAX;
	    } else {
		PNG_XMAX = real_expression();
		if (equals(c_token, ",")) {
		    c_token++;
		    PNG_YMAX = real_expression();
		}
		if (PNG_XMAX <= 0)
		    PNG_XMAX = GREG_XMAX;
		if (PNG_YMAX <= 0)
		    PNG_YMAX = GREG_YMAX;
	    }
	    term->ymax = PNG_YMAX * GD_OVERSAMPLE;
	    term->xmax = PNG_XMAX * GD_OVERSAMPLE;
	    /* EAM Apr 2003 - same tic size on both x and y axes */
	    term->v_tic = GD_OVERSAMPLE * ((PNG_XMAX < PNG_YMAX) ? PNG_XMAX/100 : PNG_YMAX/100);
	    if (term->v_tic < GD_OVERSAMPLE)
		term->v_tic = GD_OVERSAMPLE;
	    term->h_tic = term->v_tic;
	    break;
	case PNG_ENHANCED:
	    term->flags |= TERM_ENHANCED_TEXT;
	    term->put_text = ENHGD_put_text;
	    ++c_token;
	    break;
	case PNG_NOENHANCED:
	    term->flags &= ~TERM_ENHANCED_TEXT;
	    term->put_text = PNG_put_text;
	    ++c_token;
	    break;
	case PNG_TRUECOLOR:
	    png_state.TrueColor = TRUE;
	    term->flags |= TERM_ALPHA_CHANNEL;
	    term->flags |= TERM_CAN_DASH;
	    c_token++;
	    break;
	case PNG_NOTRUECOLOR:
	    png_state.TrueColor = FALSE;
	    term->flags &= ~TERM_ALPHA_CHANNEL;
	    term->flags &= ~TERM_CAN_DASH;
	    c_token++;
	    break;
	case PNG_LINEWIDTH:
	    c_token++;
	    PNG_linewidth_factor = real_expression();
	    if (PNG_linewidth_factor < 0)
		PNG_linewidth_factor = 1.0;
	    break;
	case PNG_DASHLENGTH:
	    c_token++;
	    PNG_dashlength_factor = real_expression();
	    if (PNG_dashlength_factor <= 0.2)
		PNG_dashlength_factor = 1.0;
	    break;

	/* anchor/scroll choice for sixel and kitty in-terminal output */
	case PNG_ANCHOR:
	    c_token++;
	    png_state.anchor = TRUE;
	    break;
	case PNG_SCROLL:
	    c_token++;
	    png_state.anchor = FALSE;
	    break;

	/* parse gif animation options */
	case GIF_ANIMATE:
	    c_token++;
	    if (strncmp("gif",term->name,3) == 0) {
		gif_anim_option = 1;
	    } else if (strncmp("sixel",term->name,5) == 0) {
		png_state.anchor = TRUE;
		break;
	    } else if (strncmp("kitty",term->name,5) == 0) {
		png_state.anchor = TRUE;
		break;
	    } else {
		int_error(c_token,"This terminal does not support animation");
	    }
	    png_state.animate = TRUE;
	    png_state.frame_count = 0;
	    png_state.frame_delay = 10;
	    break;
	case GIF_DELAY:
	    if (strncmp("gif",term->name,3))
		int_warn(c_token,"This terminal does not support animation");
	    c_token++;
	    png_state.frame_delay = int_expression();
	    if (png_state.frame_delay <= 0)
		png_state.frame_delay = 10;
	    gif_anim_option = 1;
	    break;
	case GIF_LOOP:
	    if (strncmp("gif",term->name,3))
		int_warn(c_token,"This terminal does not support animation");
	    c_token++;
	    png_state.loop_count = int_expression();
	    gif_anim_option = 1;
	    break;
	case GIF_NOOPT:	/* Deprecated (gif optimization never worked) */
	case GIF_OPT:
	    break;
	case PNG_BUTT:
	    png_state.linecap = BUTT;
	    c_token++;
	    break;

	case PNG_ROUNDED:
	    png_state.linecap = ROUNDED;
	    c_token++;
	    break;

	case PNG_SQUARE:
	    png_state.linecap = SQUARE;
	    c_token++;
	    break;

	case PNG_BACKGROUND:
	    c_token++;
	    png_state.rgb_table[0] = parse_color_name();
	    png_state.n_colors = 1;
	    break;

	case PNG_OTHER:
	default:
	    /* not "size" */
	    string = gp_input_line + token[c_token].start_index;

#ifdef HAVE_GD_TTF
	    /* Check for explicit TTF font size */
	    if (sscanf(string, "%lf", &tmp) == 1) {
		if (tmp > 0 && tmp < 999)
		    png_state.default_ttfsize = tmp;
		else
		    int_warn(c_token,"illegal font size");
		c_token++;
	        break;
	    }
#endif

	    if (sscanf(string, "x%lx", &color) == 1)
		int_error(c_token, "obsolete color option");
	    else
		int_error(c_token, "unrecognized terminal option");
	    break;
	}
    }

    if (gif_anim_option) {
#ifndef GIF_ANIMATION /* animated gifs not supported by the current GD library */
	png_state.animate = FALSE;
	int_warn(NO_CARET, "gif animation options ignored (not compiled into this binary)");
#endif
    }

#ifdef HAVE_GD_TTF
    /* If no font has been chosen but there is a default, use it */
    if (!png_state.ttffont && !png_state.use_builtin) {
	char *external_default = getenv("GNUPLOT_DEFAULT_GDFONT");
	int brect[8];
	char *err;

	if (external_default)
		png_state.ttffont = gp_strdup(external_default);
	else	/* Might as well try some plausible font; it's no worse than failing immediately */
		png_state.ttffont = gp_strdup("arial");

	free(png_state.default_ttffont);
	png_state.default_ttffont = gp_strdup(png_state.ttffont);
	if (png_state.default_ttfsize == 0)
		png_state.default_ttfsize = 2 * (term->h_char / GD_OVERSAMPLE) - 2;

	/* First try the old GDFONTPATH mechanism for locating fonts */
	(void)gdUseFontConfig(0);
	err = gdImageStringFT(NULL, &brect[0], 0,
		png_state.ttffont, png_state.default_ttfsize*png_state.fontscale,
		0.0, 0, 0, "test");

	/* If that didn't work, try again using fontconfig mechanism */
	if (err && gdUseFontConfig(1)) {
	    err = gdImageStringFT(NULL, &brect[0], 0,
		png_state.ttffont, png_state.default_ttfsize*png_state.fontscale,
		0.0, 0, 0, "test");
	}

	/* If we still haven't found the font, punt to the internal non-TTF default set */
	if (err) {
		fprintf(stderr,"%s when opening font \"%s\", using internal non-scalable font\n",
			err, png_state.ttffont);
		free(png_state.ttffont);
		free(png_state.default_ttffont);
		png_state.ttffont = NULL;
		png_state.default_ttffont = NULL;
	}

    }

    /* If no explicit TTF font size found, generate default */
    if (!(png_state.default_ttfsize > 0))
	png_state.default_ttfsize = 2 * (term->h_char / GD_OVERSAMPLE) - 2;
    png_state.ttfsize = png_state.default_ttfsize;

    /* Find approximate character width of selected TTF font   */
    /* This is needed in order to set appropriate border width */
    if (png_state.default_ttffont) {
	int brect[8];
	char *err;
	err = gdImageStringFT(NULL, &brect[0], 0,
		png_state.default_ttffont, png_state.default_ttfsize*png_state.fontscale,
		0.0, 0, 0, "f00000000g");
	if (!err) {
	    term->h_char = (.11 * (double)(brect[2] - brect[0]) + 0.5) * GD_OVERSAMPLE;
	    term->v_char = (1.1 * (double)(brect[1] - brect[7]) + 0.5) * GD_OVERSAMPLE;
	    /* Exact center-to-baseline offset from font metrics.
	     * Measurement at (0,0): brect[7]=-ascent, brect[1]=descent.
	     * center = (brect[7]+brect[1])/2, baseline at 0.
	     * offset = 0 - center = -(brect[7]+brect[1])/2 */
	    png_state.baseline_offset = -(brect[7] + brect[1]) / 2.0 * GD_OVERSAMPLE;
	}
    }
#endif

    /* This code is shared by png, gif, and jpeg terminal types */
    if (!strcmp(term->name,"jpeg"))
	png_state.flags &= ~PNG_USE_TRANSPARENT;

    /* now generate options string */

    if (png_state.flags & PNG_USE_TRANSPARENT) {
	strcat(term_options, "transparent ");
    }
    if (png_state.flags & PNG_USE_INTERLACE) {
	strcat(term_options, "interlace ");
    }
    /* JPEG files are always 24-bit color */
    if (strcmp(term->name, "jpeg") == 0) {
	png_state.TrueColor = TRUE;
	term->flags |= TERM_ALPHA_CHANNEL;
    } else if (png_state.TrueColor) {
	strcat(term_options, "truecolor ");
    } else {
	strcat(term_options, "notruecolor ");
    }
    if (!(png_state.flags & PNG_USE_CROP)) {
	strcat(term_options, "no");
    }
    strcat(term_options, "crop ");

    if (term->flags & TERM_ENHANCED_TEXT) {
	strcat(term_options, "enhanced ");
    }

    if (PNG_linewidth_factor != 1.0)
	sprintf(term_options + strlen(term_options),
	    "linewidth %3.1f ", PNG_linewidth_factor);

    if (PNG_dashlength_factor != 1.0)
	sprintf(term_options + strlen(term_options),
	    "dashlength %3.1f ", PNG_dashlength_factor);

    sprintf(term_options + strlen(term_options),
	png_state.linecap == ROUNDED ? "rounded " :
	png_state.linecap == SQUARE  ? "square "  : "butt ");

    if ((strncmp("kitty",term->name,5) == 0)
    ||  (strncmp("sixel",term->name,5) == 0)) {
	sprintf(term_options + strlen(term_options),
		png_state.anchor ? "anchor " : "scroll ");
    }

    if (png_state.animate) {
	sprintf(term_options + strlen(term_options),
	    "animate delay %d loop %d ",
	    png_state.frame_delay, png_state.loop_count);
    }

    sprintf(term_options + strlen(term_options),
	    "size %d,%d ", PNG_XMAX, PNG_YMAX);

    if (png_state.n_colors == 1)
	sprintf(term_options + strlen(term_options),
	    "background \"#%06x\" ", png_state.rgb_table[0]);

    if (png_state.ttffont) {
	if (png_state.fontscale != 1.0)
	    sprintf(term_options + strlen(term_options),
		"fontscale %.1f ", png_state.fontscale);
	if (strlen(term_options) + strlen(png_state.ttffont) < sizeof(term_options) - 32)
	    sprintf(term_options + strlen(term_options),
		"font \"%s,%.1f\" ", png_state.ttffont, png_state.ttfsize);
    } else switch (term->h_char) {
    case 5:
	strcat(term_options,"tiny ");
	break;
    case 6:
	strcat(term_options, "small ");
	break;
    case 7:
    default:
	strcat(term_options, "medium ");
	break;
    case 8:
	strcat(term_options, "large ");
	break;
    case 9:
	strcat(term_options,"giant ");
	break;
    }
}


/*
 * _init()  Called once, when the device is first selected.  This procedure
 * should set up things that only need to be set once, like handshaking and
 * character sets etc...
 */
TERM_PUBLIC void
PNG_init()
{
int i;

    png_state.linetype = 0;
    png_state.linewidth = 1;

    /* Clear brush array, then initialize a few small ones */
    for (i=2; i<=MAXLINEWIDTH; i++)
	PNG_brush[i] = NULL;
}

/*
 * Internal helper routine to initialize brushes used for stroking linewidth > 1
 */
static void
PNG_init_brush(int width)
{
    PNG_BRUSH *brush = PNG_brush[width];

    if (!brush) {
	brush = gp_alloc(sizeof(PNG_BRUSH),"gd brush");
	PNG_brush[width] = brush;
	brush->last_rgb = -99;  /* Something invalid */
	if (!((brush->im = gdImageCreateTrueColor(width,width))))
	    int_error(NO_CARET,"libgd: failed to create brush structure");
	/* Whatever is chosen here is unavailable as a brush color */
	brush->bgnd = gdImageColorAllocate( brush->im, 254, 253, 252 );
	gdImageSaveAlpha(brush->im, 1);
	gdImageFill(brush->im, 0, 0, brush->bgnd);
	gdImageColorTransparent(brush->im, brush->bgnd);
    }

    if (png_state.color != brush->last_rgb) {
	if (png_state.TrueColor) {
	    int alpha = (png_state.rgb >> 25) & 0x7f;
	    /* NB: gdEffectAlphaBlend does not work! */
	    gdImageAlphaBlending(brush->im, gdEffectReplace);
	    brush->fgnd = gdImageColorExactAlpha(png_state.image,
		(png_state.rgb >> 16) & 0xff,
		(png_state.rgb >> 8) & 0xff,
		 png_state.rgb & 0xff,
		 alpha & 0x7f);
	} else {
	    brush->fgnd = gdImageColorResolve(brush->im,
		gdImageRed(png_state.image,png_state.color),
		gdImageGreen(png_state.image,png_state.color),
		gdImageBlue(png_state.image,png_state.color) );
	}
	brush->last_rgb = png_state.color;

	/* The simplest choice is to fill the entire brush (square nib).
	 * Logically it would be better to approximate a circular nib by
	 * selectively coloring the individual pixels of the brush image,
	 * but the difference is only apparent for dots, not lines.
	 * Version 6: Approximate by removing the corners.
	 */
	gdImageFilledRectangle(brush->im, 0, 0, width-1, width-1, brush->fgnd);
	if (width > 2) {
	    gdImageSetPixel(brush->im, 0, 0, brush->bgnd);
	    gdImageSetPixel(brush->im, 0, width-1, brush->bgnd);
	    gdImageSetPixel(brush->im, width-1, 0, brush->bgnd);
	    gdImageSetPixel(brush->im, width-1, width-1, brush->bgnd);
	}

    }
}

/*
 * _reset()  Called when gnuplot is exited, the output device changed or
 * the terminal type changed.  This procedure should reset the device,
 * possibly flushing a buffer somewhere or generating a form feed.
 */
TERM_PUBLIC void
PNG_reset()
{
    int i;
    PNG_clip_state(NULL, 0);
    /* EAM - Clean up the brushes used for linewidth */
    for (i=2; i<=MAXLINEWIDTH; i++) {
	if (PNG_brush[i]) {
	    if (PNG_brush[i]->im)
		gdImageDestroy(PNG_brush[i]->im);
	    PNG_brush[i] = NULL;
	}
    }
    if (PNG_fill_tile.im) {
	gdImageDestroy(PNG_fill_tile.im);
	PNG_fill_tile.im = (gdImagePtr)0;
    }
#ifdef GIF_ANIMATION
    if (png_state.animate && !strncmp(term->name,"gif",3)) {
	gdImageGifAnimEnd(gpoutfile);
	fprintf(stderr,"%d frames in animation sequence\n", png_state.frame_count);
	png_state.frame_count = 0;
	png_state.animate = FALSE;
    }
#endif
}

/*
How this works: Gray interval [0;1] will be mapped to interval
[0;sm_palette.colors-1] those r,g,b components are mapped by the array
below palette.offset equals 0 since png_smooth_color[0..colors] are
from ColorAllocate
*/
static int png_smooth_color[gdMaxColors];

  /* TODO: how to recover from a multiplot with two colour pm3d maps?
     They must use the same palette! Or palette size must be
     restricted to certain number of colours---a new user's option
  */

TERM_PUBLIC int PNG_make_palette (t_sm_palette *palette)
{
    int i;
    if (palette == NULL) {
	/* If the output format is TrueColor there in no color limit */
	if (png_state.TrueColor)
	    return(0);

	/* return maximal number of colours in a PNG palette */
	i = gdMaxColors /*256*/ - gdImageColorsTotal(png_state.image);
	/* the latter is the number of currently allocated colours. We want
	   to allocate the rest */
	/*BACK PLEASE  fprintf(stderr,"colors in PNG palette=%i\n",(int)gdMaxColors); */
	if (i == 0) {
	    i = (sm_palette.colors <= 0) ? -1 : sm_palette.colors;
	        /* (no more colorus) : (previous palette (obviously multiplot mode)) */
	}
	return i;
    }
    if (0 == gdMaxColors /*256*/ - gdImageColorsTotal(png_state.image))
	return 0; /* reuse previous palette (without warning) */
    for (i = 0; i < sm_palette.colors; i++) {
	png_smooth_color[i] = gdImageColorAllocate(png_state.image,
	    (int)( palette->color[i].r * 255 + 0.5 ), /* r,g,b values for png */
	    (int)( palette->color[i].g * 255 + 0.5 ), /* terminal are [0;255] */
	    (int)( palette->color[i].b * 255 + 0.5 ) );
    }
    return 0;
}

TERM_PUBLIC
void PNG_set_color (t_colorspec *colorspec)
{
    double gray = colorspec->value;
    int save;

    /* A color change ends the current transparent polyline path */
    PNG_flush_pending_endcap();
    if (png_state.alpha_layer_active)
	PNG_alpha_layer_composite();

    switch (colorspec->type) {

    case TC_LT:
	save = png_state.linetype;
	PNG_linetype(colorspec->lt);
	png_state.linetype = save;
	break;

    case TC_RGB:
	png_state.rgb = colorspec->rgbcolor;
	if (png_state.TrueColor)
	    png_state.color = gdImageColorExactAlpha(png_state.image,
		(colorspec->rgbcolor >> 16) & 0xff,
		(colorspec->rgbcolor >> 8) & 0xff,
		 colorspec->rgbcolor & 0xff,
		(colorspec->rgbcolor >> 25) & 0x7f);
	else
	    png_state.color = gdImageColorResolve(png_state.image,
		(colorspec->rgbcolor >> 16) & 0xff,
		(colorspec->rgbcolor >> 8) & 0xff,
		colorspec->rgbcolor & 0xff);
	break;

    case TC_FRAC:
	if (png_state.TrueColor) {
	    rgb255_color color;
	    rgb255maxcolors_from_gray(gray, &color);
	    png_state.color = gdImageColorResolve(png_state.image,
		(int)color.r, (int)color.g, (int)color.b);
	    png_state.rgb = (color.r << 16) + (color.g << 8) +color.b;
	    return;
	} else {
	    int png_color;
	    if (CHECK_SMPAL_IS_DISCRETE_GRADIENT) {
		png_color = index_from_gray(gray);
	    } else {
		if (sm_palette.use_maxcolors > 0)
		    gray = quantize_gray(gray);
		png_color = (gray <= 0) ? 0 : (int)(gray * sm_palette.colors);
	        if (png_color >= sm_palette.colors)
		    png_color = sm_palette.colors - 1;
	    }
	    /* map [0;1] to interval [0;png_smooth_colors-1] */
	    png_state.color = png_smooth_color[ png_color ];
	}
	break;

    default:
	break;
    }

    /* This is correct, but currently the resulting gdAntiAliased is not used */
    gdImageSetAntiAliased(png_state.image, png_state.color);
}

TERM_PUBLIC
void PNG_filled_polygon(int points, gpiPoint *corners)
{
    int i;
    int fillpar = corners->style >> 4;
    int color = png_state.color;

    /* since gpiPoint carries more than just x and y if
     * we have EXTENDED_COLOR_SPECS defined, we need to
     * copy it to the gdPointPtr struct; make it static
     * so that is faster (joze) */
    static gdPointPtr gd_corners = (gdPointPtr) 0;
    static unsigned int size = 0;
    if (points > size) {
	size = points;
	gd_corners = gp_realloc(gd_corners, sizeof(gdPoint) * size,
	    "PNG_filled_polygon->gd_corners");
    }
    for (i = 0; i < points; i++) {
	gd_corners[i].x = GD_PX(corners[i].x);
	gd_corners[i].y = GD_Y(corners[i].y);
    }

    switch (corners->style & 0xf) {
	case FS_EMPTY: /* fill with background color */
	    color = png_state.color_table[0];
	    break;
	case FS_SOLID: /* solid fill */
	    color = PNG_FillSolid(fillpar);
	    break;
	case FS_TRANSPARENT_SOLID:
	    if (png_state.TrueColor)
		color = PNG_FillTransparent(fillpar);
	    else
		color = PNG_FillSolid(fillpar);
	    break;
	case FS_PATTERN: /* pattern fill */
	case FS_TRANSPARENT_PATTERN:
	    color = PNG_FillPattern(corners->style);
	    break;
	default:
	    color = png_state.color;
	    break;
    }

    gdImageFilledPolygon(png_state.image, gd_corners, points, color);
}

/*
 * This function is used for filledboxes
 * style parameter is some garbled hash combining fillstyle and filldensity
 */
TERM_PUBLIC void
PNG_boxfill(
    int style,
    unsigned int x, unsigned int y,
    unsigned int width, unsigned int height)
{
    unsigned int x1, y1, x2, y2;
    int          color;

    /* fillpar:
     * - solid   : 0 - 100
     * - pattern : 0 - 100
     */
    int fillpar = style >> 4;

    switch (style & 0xf) {
	case FS_EMPTY: /* fill with background color */
	    color = png_state.color_table[0];
	    break;
	case FS_SOLID: /* solid fill */
	    color = PNG_FillSolid(fillpar);
	    break;
	case FS_TRANSPARENT_SOLID:
	    if (png_state.TrueColor)
		color = PNG_FillTransparent(fillpar);
	    else
		color = PNG_FillSolid(fillpar);
	    break;
	case FS_PATTERN: /* pattern fill */
	case FS_TRANSPARENT_PATTERN:
	    color = PNG_FillPattern(style);
	    break;
	default:
	    /* should never happen */
	    color = png_state.color;
	    break;
    }

    /* Convert each edge from inflated terminal coords to pixel coords
     * independently, so that adjacent boxes sharing an edge always
     * produce the same pixel boundary (no rounding gaps).
     */
    x1 = GD_PX(x);
    x2 = GD_PX(x + width) - 1;
    if (x2 < x1) x2 = x1;		/* at least 1 pixel wide */
    y1 = GD_Y(y + height);		/* gnuplot top => smallest pixel y */
    y2 = GD_Y(y);			    /* gnuplot bottom => largest pixel y */
    if (y1 > y2) y1 = y2;		/* at least 1 pixel tall */
    gdImageFilledRectangle(png_state.image, x1, y1, x2, y2, color);
}

/*
 * _graphics()  Called just before a plot is going to be displayed.  This
 * procedure should set the device into graphics mode.  Devices which can't
 * be used as terminals (like plotters) will probably be in graphics mode
 * always and therefore won't need this.
 */
TERM_PUBLIC void
PNG_graphics()
{
    int i;
    unsigned int rgb;
    unsigned int n_colors = GD_DEFINED_COLORS;

    /* avoid to pre-allocate colors for the sixel terminal in indexed mode */
    if ((strcmp("sixelgd", term->name) == 0) && !png_state.TrueColor)
	n_colors = 1;

    for (i = png_state.n_colors; i < n_colors; i++)
	png_state.rgb_table[i] = pm3d_color_names_tbl[i].value;
    if (png_state.n_colors < n_colors)
	png_state.n_colors = n_colors;

    /* TrueColor images default to a black background; load white instead.	*/
    /* If PNG_USE_TRANSPARENT, store the background alpha in the output file	*/
    /* but apply alpha for the rest of the image internally. Otherwise you	*/
    /* see only background through the topmost transparent layer.		*/
    if (png_state.TrueColor) {
        unsigned int brgb = png_state.rgb_table[0];
	png_state.image = gdImageCreateTrueColor(PNG_XMAX, PNG_YMAX);
	if (!png_state.image)
	    int_error(NO_CARET,"libgd: failed to create output image structure");
	if (png_state.flags & PNG_USE_TRANSPARENT) {
	    rgb = gdImageColorAllocateAlpha(png_state.image,
		(brgb >> 16) & 0xff, (brgb >> 8) & 0xff, brgb & 0xff, 127);
	    gdImageSaveAlpha(png_state.image, 1);
	    gdImageAlphaBlending(png_state.image, gdEffectReplace);
	} else {
	    rgb = gdImageColorAllocate(png_state.image,
		(brgb >> 16) & 0xff, (brgb >> 8) & 0xff, brgb & 0xff);
	}
	gdImageFill(png_state.image, 1, 1, rgb);
	gdImageAlphaBlending(png_state.image, gdEffectNormal);

    } else
	png_state.image = gdImageCreate(PNG_XMAX, PNG_YMAX);
    if (!png_state.image)
	int_error(NO_CARET,"libgd: failed to create output image structure");

    png_state.height = PNG_YMAX * GD_OVERSAMPLE - 1;
    png_state.charw = term->h_char;	/* already inflated */
    png_state.charh = term->v_char;	/* already inflated */
    if (png_state.baseline_offset <= 0.0)
	png_state.baseline_offset = png_state.charh / 4.0;  /* fallback for built-in fonts */
    png_state.font = png_state.default_font;
    png_state.color = 0;
    png_state.dashfraction = -1.0;
    png_state.alpha_layer_active = FALSE;
    png_state.alpha_main_image = NULL;

    for (i = 0; i < png_state.n_colors; i++) {
	rgb = png_state.rgb_table[i];
	png_state.color_table[i] =
	    gdImageColorAllocate(png_state.image, (rgb >> 16) & 0xff,
				 (rgb >> 8) & 0xff, rgb & 0xff);
    }

    if (png_state.flags & PNG_USE_TRANSPARENT)
	gdImageColorTransparent(png_state.image, png_state.color_table[0]);
    else
	gdImageColorTransparent(png_state.image, -1);

    /* Fix for truecolor and transparent options */
    if (strcmp("sixelgd", term->name) == 0 &&
        png_state.TrueColor && png_state.flags & PNG_USE_TRANSPARENT) {
	gdImageAlphaBlending(png_state.image, gdEffectReplace);
	gdImageFill(png_state.image, 1, 1, png_state.color_table[0]);
	gdImageAlphaBlending(png_state.image, gdEffectNormal);
    }
}

/*
 * _text()  Called immediately after a plot is displayed.  This procedure
 * should set the device back into text mode if it is also a terminal, so
 * that commands can be seen as they're typed.  Again, this will probably
 * do nothing if the device can't be used as a terminal.
 */
TERM_PUBLIC void
PNG_text()
{
    PNG_clip_state(NULL, 0);
    PNG_flush_pending_endcap();
    if (png_state.alpha_layer_active)
	PNG_alpha_layer_composite();
    PNG_alpha_layer_destroy();
    image_do_crop();
    if (png_state.flags & PNG_USE_INTERLACE)
	gdImageInterlace(png_state.image, 1);
    gdImagePng(png_state.image, gpoutfile);
    gdImageDestroy(png_state.image);
}

/* _move(x,y)  Called at the start of a line.  The cursor should move to the
 * (x,y) position without drawing.
 */
TERM_PUBLIC void
PNG_move(unsigned int x, unsigned int y)
{
    /* End of polyline path: flush deferred endcap and composite alpha layer */
    PNG_flush_pending_endcap();
    if (png_state.alpha_layer_active)
	PNG_alpha_layer_composite();
    png_state.x = x;
    png_state.y = y;
    /* Reset dash pattern position at the start of a new path */
    PNG_dash_pos = 0.0;
    /* Reset direction state for join disc logic */
    PNG_prev_seg_dx = 0.0;
    PNG_prev_seg_dy = 0.0;
    PNG_prev_dash_dx = 0.0;
    PNG_prev_dash_dy = 0.0;
}

/* _vector(x,y)  Called when a line is to be drawn.  This should display a line
 * from the last (x,y) position given by _move() or _vector() to this new (x,y)
 * position.
 */
TERM_PUBLIC void
PNG_vector(unsigned int x, unsigned int y)
{
    int lw = png_state.linewidth;

    if (png_state.linetype == LT_NODRAW) {
	/* Treat this as PNG_move */
	;

    /* LT_AXIS is rendered as a dotted line, used for zeroaxis and grid lines. */
    /* Nov 2014 - rewritten using the algorithm from the canvas terminal. */
    } else if (png_state.linetype == LT_AXIS
	       && png_state.dashtype == DASHTYPE_SOLID) {
	/* LT_AXIS with no dashtype override: use legacy dotted pattern */
	static int last_lw = -1;
	static int last_color = -1;
	static double dashpattern[4] = {0.1, 0.5, 0.6, 1.0};

	double delx = GD_PXF(x) - GD_PXF(png_state.x);
	double dely = GD_YF(y) - GD_YF(png_state.y);
	double stride = sqrt(delx*delx + dely*dely) / (8. * PNG_dashlength_factor * lw);

	double new_x, new_y;
	double last_x = GD_PXF(png_state.x), last_y = GD_YF(png_state.y);
	int i;
	double this_step;

	/* Adjust the style when linewidth or color has changed. */
	if (png_state.dashfraction < 0 || lw != last_lw || last_color != png_state.color) {
	    PNG_init_brush(lw);
	    gdImageSetBrush(png_state.image, PNG_brush[lw]->im);
	    last_lw = lw;
	    last_color = png_state.color;
	    png_state.dashfraction = 0.0;
	}

	while (stride > 0) {
	    for (i=0; dashpattern[i] <= png_state.dashfraction; i++);
	    this_step = dashpattern[i] - png_state.dashfraction;
	    if (stride > this_step) {
		new_x = last_x + delx * this_step / stride;
		new_y = last_y + dely * this_step / stride;
		stride -= this_step;
		png_state.dashfraction = dashpattern[i];
		delx = GD_PXF(x) - new_x;
		dely = GD_YF(y) - new_y;
	    } else {
		new_x = GD_PXF(x);
		new_y = GD_YF(y);
		png_state.dashfraction += stride;
		stride = 0;
	    }
	    if (i%2 == 0) {
		/* dashes are fine for thin lines, but true dots look better */
		/* when the line is thick.			             */
		if (lw > 2) {
		    if (png_state.dashfraction >= dashpattern[0])
		    gdImageFilledArc(png_state.image,
				     (int)(new_x + 0.5), (int)(new_y + 0.5),
				     2 * lw, 2 * lw,
				     0, 360, png_state.color, gdArc);
		} else {
		    gdImageLine(png_state.image,
				(int)(last_x + 0.5), (int)(last_y + 0.5),
				(int)(new_x + 0.5), (int)(new_y + 0.5),
				gdBrushed );
		}
	    }
	    last_x = new_x;
	    last_y = new_y;
	    if (png_state.dashfraction >= 1.0)
		png_state.dashfraction = 0.0;
	}

    /* Dashed or solid thick TrueColor lines: use our AA rasterizer for
     * proper antialiasing, endcap, and join handling.
     * For linewidth 1 without a dash pattern the native libgd antialiased
     * path works well enough, so we fall through to the final branch.
     */
    } else if (png_state.dashtype >= 1
	       || png_state.dashtype == DASHTYPE_CUSTOM
	       || (png_state.TrueColor && png_state.linewidth > 1)) {
	float *pattern = NULL;
	double scale = 0.0;
	int color = png_state.color;

	/* Activate alpha layer for semi-transparent lines to avoid
	 * overlap artifacts from sub-segment and join-disc rendering.
	 */
	if (png_state.TrueColor && gdTrueColorGetAlpha(color) > 0
	    && !png_state.alpha_layer_active)
	    PNG_alpha_layer_begin(color);
	if (png_state.alpha_layer_active)
	    color = png_state.alpha_opaque_color;

	/* Resolve dash pattern and scale (NULL pattern = solid line) */
	if (png_state.dashtype == DASHTYPE_CUSTOM) {
	    pattern = png_state.custom_dashpattern.pattern;
	    /* Custom string patterns (".-_") have DSCALE=10 baked in;
	     * apply empirical_scale=0.25 to match pngcairo visual output. */
	    scale = 0.25 * png_state.linewidth_f * PNG_dashlength_factor;
	} else if (png_state.dashtype > 0) {
	    pattern = PNG_dashpatterns[png_state.dashtype];
	    scale = png_state.linewidth_f * PNG_dashlength_factor;
	}
	if (pattern && scale < 0.1) scale = 0.1;

	PNG_draw_aa_vector(
	    GD_PXF(png_state.x), GD_YF(png_state.y),
	    GD_PXF(x),           GD_YF(y),
	    pattern, scale, png_state.linewidth, color);

    /* All other (not dashed, not thick TrueColor) vectors */
    } else {
	if (png_state.linecap != ROUNDED) {
	    /* Assume working antialiasing (gd version >? 2.0.12) */
	    gdImageSetThickness(png_state.image,png_state.linewidth);
	    gdImageSetAntiAliased(png_state.image, png_state.color);
	    gdImageLine(png_state.image, GD_PX(png_state.x), GD_Y(png_state.y),
			GD_PX(x), GD_Y(y), gdAntiAliased);
	} else {
	    /* EAM - Implement linewidth by using a brush */
	    PNG_init_brush(lw);
	    gdImageSetBrush(png_state.image, PNG_brush[lw]->im);
	    gdImageLine(png_state.image, GD_PX(png_state.x), GD_Y(png_state.y),
			GD_PX(x), GD_Y(y), gdBrushed );
	}
    }

    /* Update previous-direction state (for join disc logic) */
    {
	double dx = (double)x - (double)png_state.x;
	double dy = (double)y - (double)png_state.y;
	double len = sqrt(dx*dx + dy*dy);
	if (len > 0.0) {
	    PNG_prev_seg_dx = dx / len;
	    PNG_prev_seg_dy = dy / len;
	}
    }

    png_state.x = x;
    png_state.y = y;
}

/* _linetype(lt)  Called to set the line type before text is displayed or
 * line(s) plotted.
 * Negative linetypes are defined in gadgets.h
 * lt 0 and upwards are used for plots 0 and upwards.
 * If _linetype() is called with lt greater than the available line types,
 * it should map it to one of the available line types.
 */
TERM_PUBLIC void
PNG_linetype(int type)
{
    int typeindex;

    if (type >= (GD_DEFINED_COLORS - 3))
	type %= (GD_DEFINED_COLORS - 3);
    typeindex = type;
    if (typeindex < -3) /* LT_BACKGROUND, LT_UNDEFINED */
	typeindex = -3;	/* Draw in background color */

    if (typeindex + 3 >= png_state.n_colors) {
	int rgb = pm3d_color_names_tbl[typeindex + 3].value;
	png_state.color = gdImageColorResolve(png_state.image,
				(rgb >> 16) & 0xff, (rgb >> 8) & 0xff, rgb & 0xff);
	png_state.rgb = rgb;
    } else {
	png_state.color = png_state.color_table[typeindex + 3];
	png_state.rgb = png_state.rgb_table[typeindex + 3];
    }

    png_state.linetype = type;	/* NB: may still have type <= LT_NODRAW */

    /* Reset dash state */
    PNG_flush_pending_endcap();
    if (png_state.alpha_layer_active)
	PNG_alpha_layer_composite();
    png_state.dashtype = DASHTYPE_SOLID;
    PNG_dash_pos = 0.0;

    if (type == LT_AXIS)
	png_state.dashfraction = -1.0;
}

/* Use the "brush" tools in the gd library to control line width.
 * Pre-define brushes for linewidths 2, 3, 4, 5, 6 (1 doesn't need a brush!).
 * Here we just remember the state.
 */
TERM_PUBLIC void
PNG_linewidth(double linewidth)
{
    png_state.linewidth_f = PNG_linewidth_factor * linewidth;
    if (png_state.linewidth_f > MAXLINEWIDTH) png_state.linewidth_f = MAXLINEWIDTH;
    if (png_state.linewidth_f < 1.0) png_state.linewidth_f = 1.0;
    png_state.linewidth = (int)(png_state.linewidth_f + 0.49);
    if (png_state.linewidth > MAXLINEWIDTH) png_state.linewidth = MAXLINEWIDTH;
    if (png_state.linewidth < 1) png_state.linewidth = 1;
}

/*
 * PNG_dashtype - Set the dash pattern for subsequent line drawing.
 * type >= 1 selects a built-in pattern; DASHTYPE_CUSTOM uses the
 * caller-supplied pattern.  DASHTYPE_SOLID clears any dash.
 */
TERM_PUBLIC void
PNG_dashtype(int type, t_dashtype *custom_dash_pattern)
{
    PNG_flush_pending_endcap();
    if (png_state.alpha_layer_active)
	PNG_alpha_layer_composite();
    PNG_dash_pos = 0.0;

    /* Non-TrueColor mode cannot anti-alias properly; force solid */
    if (!png_state.TrueColor) {
	png_state.dashtype = DASHTYPE_SOLID;
	return;
    }

    if (type == DASHTYPE_CUSTOM && custom_dash_pattern
    &&  custom_dash_pattern->pattern[0] > 0) {
	png_state.dashtype = DASHTYPE_CUSTOM;
	png_state.custom_dashpattern = *custom_dash_pattern;
    } else if (type > 0) {
	/* Cycle through the built-in dash patterns */
	png_state.dashtype = type % PNG_NUM_DASHTYPES;
    } else {
	/* DASHTYPE_SOLID, DASHTYPE_AXIS, or unknown */
	/* FIXME: other terminal use a fine dotted line for DASHTYPE_AXIS */
	png_state.dashtype = DASHTYPE_SOLID;
    }
}

/* _put_text(x,y,str)  Called to display text at the (x,y) position,
 * while in graphics mode.   The text should be vertically (with respect
 * to the text) justified about (x,y).  The text is rotated according
 * to _text_angle and then horizontally (with respect to the text)
 * justified according to _justify_text.
 * Dec 2025: Modified to work with gd 2.4.0 and libraqm 0.10.3 after
 * a series of changes to both libraries that broke rotated text.
 */
#ifdef HAVE_GD_TTF
TERM_PUBLIC void
PNG_put_text(unsigned int x, unsigned int y, const char *string)
{
    /* Convert inflated terminal coords to pixel coords */
    int px = GD_PX(x);
    int py = GD_Y(y);

    /* Mar 2011 - added to handle SJIS/UTF8 conversion */
    if (contains8bit(string)) {
	gd_iconv((char **)(&string));
    }

    if (png_state.ttffont) {
	int brect[8]; char *err;
	/* Draw once with a NULL image and no rotation to get the text width,
	 * then draw it again, centered.
	 */
	err = gdImageStringFT(NULL, brect, png_state.color,
			png_state.ttffont, png_state.ttfsize*png_state.fontscale,
			0., px, py, (char *)string);
	if (err) {
	    fprintf(stderr,"gdImageStringFT: %s while printing string %s with font %s\n",
		err,string,png_state.ttffont);
	} else {
	    int textwidth = (brect[2]-brect[0]);
	    int xoffset =  textwidth * cos(png_state.angle * M_PI_2/90.);
	    int yoffset = -textwidth * sin(png_state.angle * M_PI_2/90.);
	    /* Exact centering: compute center-to-baseline offset from
	     * this string's actual brect.  The measurement was at baseline=py,
	     * so text center = (brect[7]+brect[1])/2, and offset = py - center.
	     * Apply in inflated space before pixel conversion. */
	    {
		double bl_offset_px = py - (brect[7] + brect[1]) / 2.0;
		double bl_offset = bl_offset_px * GD_OVERSAMPLE;
		double ax = (double)x + sin(png_state.angle * M_PI_2/90.) * bl_offset;
		double ay = (double)y - cos(png_state.angle * M_PI_2/90.) * bl_offset;
		px = (int)(ax / (double)GD_OVERSAMPLE + 0.5);
		py = (int)(((double)png_state.height - ay) / (double)GD_OVERSAMPLE + 0.5);
	    }
	    switch (png_state.justify) {
		case RIGHT:
				px -= xoffset;
				py -= yoffset;
				break;
		case CENTRE:
				px -= xoffset / 2.;
				py -= yoffset / 2.;
				break;
		case LEFT:
		default:	break;
	    }
	    err = gdImageStringFT(png_state.image, brect, png_state.color,
			png_state.ttffont, png_state.ttfsize*png_state.fontscale,
			png_state.angle * M_PI_2 / 90.,
			px, py, (char *)string);
	    if (err)
		fprintf(stderr,"gdImageStringFT: %s while printing string %s with font %s\n",
		    err,string,png_state.ttffont);

	    if (!ENHgd_sizeonly) {
		int xmax = GPMAX(brect[2],brect[6]);
		int xmin = GPMIN(brect[0],brect[4]);
		int ymax = GPMIN(brect[1],brect[3]);
		int ymin = GPMAX(brect[5],brect[7]);
		if (xmin < bounding_box[0]) bounding_box[0] = xmin;
		if (xmax > bounding_box[2]) bounding_box[2] = xmax;
		if (ymin < bounding_box[1]) bounding_box[1] = ymin;
		if (ymax > bounding_box[3]) bounding_box[3] = ymax;
	    }

	}
    } else if (png_state.angle != 0) {
	int charw_px = GD_PX(png_state.charw);
	/* Apply charh/2 offset in inflated space before pixel conversion */
	px = (int)(((double)x - (double)png_state.charh / 2.0) / (double)GD_OVERSAMPLE + 0.5);
	switch (png_state.justify) {
	    case RIGHT:	py += charw_px * strlen(string);
			break;
	    case CENTRE:py += charw_px * strlen(string) / 2;
			break;
	    case LEFT:
	    default:	break;
	}
	gdImageStringUp(png_state.image, png_state.font,
			px, py,
			(unsigned char *)string, png_state.color);
    } else {
	int charw_px = GD_PX(png_state.charw);
	/* Apply charh/2 offset in inflated space before pixel conversion */
	py = (int)(((double)png_state.height - ((double)y + (double)png_state.charh / 2.0)) / (double)GD_OVERSAMPLE + 0.5);
	switch (png_state.justify) {
	    case RIGHT:	px -= charw_px * strlen(string);
			break;
	    case CENTRE:px -= charw_px * strlen(string) / 2;
			break;
	    case LEFT:
	    default:	break;
	}
	gdImageString(png_state.image, png_state.font,
		      px, py,
		      (unsigned char *)string, png_state.color);
    }

}

#else  /* not HAVE_GD_TTF */

TERM_PUBLIC void
PNG_put_text(unsigned int x, unsigned int y, const char *string)
{
    int px = GD_PX(x);
    int py;

    if (png_state.angle == 0) {
	/* Apply charh/2 offset in inflated space before pixel conversion */
	py = (int)(((double)png_state.height - ((double)y + (double)png_state.charh / 2.0)) / (double)GD_OVERSAMPLE + 0.5);
	gdImageString(png_state.image, png_state.font,
		      px, py,
		      (unsigned char *)string, png_state.color);
    } else {
	/* Apply charh/2 offset in inflated space before pixel conversion */
	px = (int)(((double)x - (double)png_state.charh / 2.0) / (double)GD_OVERSAMPLE + 0.5);
	py = GD_Y(y);
	gdImageStringUp(png_state.image, png_state.font,
			px, py,
			(unsigned char *)string, png_state.color);
    }
}

#endif /* HAVE_GD_TTF */


TERM_PUBLIC int
PNG_text_angle(float ang)
{
    while (ang < -180) ang += 360;	/* Should not be needed, but reported to */
    while (ang > 180) ang -= 360;	/* avoid a bug in some libgd versions    */
    png_state.angle = ang;
    return TRUE;
}

TERM_PUBLIC int
PNG_justify_text(enum JUSTIFY mode)
{
#ifdef HAVE_GD_TTF
    png_state.justify = mode;
    return TRUE;
#else
    return null_justify_text(mode);
#endif
}

TERM_PUBLIC void
PNG_point(unsigned int x, unsigned int y, int number)
{
    int save_color = png_state.color;
    unsigned int px, py;

    /* Use current linewidth to draw the point symbol */
    if (png_state.linewidth > 1) {
	/* EAM - Implement linewidth by using a brush */
	int lw   = png_state.linewidth;
	PNG_init_brush(lw);
	gdImageSetBrush(png_state.image, PNG_brush[lw]->im);
	png_state.color = gdBrushed;
    }

    /* Convert inflated coords to pixel coords */
    px = GD_PX(x);
    py = GD_Y(y);

    if (number < 0) { /* Dot */
	gdImageSetPixel(png_state.image, px, py, png_state.color);
	png_state.color = save_color;
	return;
    }

    switch (number % 13) {
    case 0: /* plus */
    default:
	PNG_PointPlus(px, py);
	break;
    case 1: /* X */
	PNG_PointX(px, py);
	break;
    case 2: /* star */
	PNG_PointPlus(px, py);
	PNG_PointX(px, py);
	break;
    case 3: /* box */
	gdImageRectangle(png_state.image, px - PNG_ps, py - PNG_ps,
			 px + PNG_ps, py + PNG_ps, png_state.color);
	break;
    case 4: /* box                   filled */
	gdImageFilledRectangle(png_state.image, px - PNG_ps, py - PNG_ps,
			       px + PNG_ps, py + PNG_ps, png_state.color);
	break;
    case 5: /* circle */
	gdImageArc(png_state.image, px, py, 2 * PNG_ps, 2 * PNG_ps,
		   0, 360, png_state.color);
	break;
    case 6: /* circle (disk)         filled */
	gdImageFilledArc(png_state.image, px, py, 2 * PNG_ps, 2 * PNG_ps,
		   0, 360, png_state.color, gdArc);
	break;
    case 7: /* triangle */
	PNG_Triangle(px, py, 1, gp_gdImagePolygon);
	break;
    case 8: /* triangle              filled */
	PNG_Triangle(px, py, 1, gp_gdImageFilledPolygon);
	break;
    case 9: /* upside down triangle */
	PNG_Triangle(px, py, -1, gp_gdImagePolygon);
	break;
    case 10: /* upside down triangle  filled */
	PNG_Triangle(px, py, -1, gp_gdImageFilledPolygon);
	break;
    case 11: /* diamond */
	PNG_Diamond(px, py, gp_gdImagePolygon);
	break;
    case 12: /* diamond               filled */
	PNG_Diamond(px, py, gp_gdImageFilledPolygon);
	break;
    }

    png_state.color = save_color;
}

TERM_PUBLIC int
PNG_set_font(const char *fontname)
{
    int  sep;
    double size;
    gdFontPtr font = png_state.default_font;
    char *name = gp_strdup(fontname);

    sep = strcspn(fontname,",");
    name[sep] = '\0';
    size = png_state.default_ttfsize;
    if (fontname[sep] == ',')
	sscanf(&(fontname[sep+1]),"%lf",&size);

    if (!strcmp(name,"small"))
	font = gdFontGetSmall();
    else if (!strcmp(name,"medium"))
	font = gdFontGetMediumBold();
    else if (!strcmp(name,"large"))
	font = gdFontGetLarge();
    else if (!strcmp(name,"giant"))
	font = gdFontGetGiant();
    else if (!strcmp(name,"tiny"))
	font = gdFontGetTiny();
    else if (*name) {
	/* New ttf font */
	free(png_state.ttffont);
	png_state.ttffont = gp_strdup(name);
	png_state.ttfsize = size;
    } else {
	/* Restore initial default font */
	free(png_state.ttffont);
	png_state.ttffont = gp_strdup(png_state.default_ttffont);
	png_state.ttfsize = size;
    }
    free(name);

    png_state.font  = font;
    png_state.charw = font->w * GD_OVERSAMPLE;
    png_state.charh = font->h * GD_OVERSAMPLE;

/* EAM 9-Feb-2003 Make new font size visible to higher level routines like write_multiline */
    term->h_char = font->w * GD_OVERSAMPLE;
    term->v_char = font->h * GD_OVERSAMPLE;
#ifdef HAVE_GD_TTF
    /* Find approximate character width and height of selected TTF font */
    if (png_state.ttffont) {
	int brect[8];
	char *err;
        /* First try the old GDFONTPATH mechanism for locating fonts */
	(void)gdUseFontConfig(0);
	err = gdImageStringFT(NULL, &brect[0], 0,
		png_state.ttffont, size*png_state.fontscale,
		0.0, 0, 0, "f00000000g");
	/* If that didn't work, try again using fontconfig mechanism */
	if (err && gdUseFontConfig(1)) {
	    FPRINTF((stderr,"gd.trm:%d gdUseFontConfig(1) (%s)\n",
		    __LINE__, png_state.ttffont));
	    err = gdImageStringFT(NULL, &brect[0], 0,
		png_state.ttffont, size*png_state.fontscale,
		0.0, 0, 0, "f00000000g");
	}
	if (!err) {
	    term->h_char = (.11 * (double)(brect[2] - brect[0]) + 0.5) * GD_OVERSAMPLE;
	    term->v_char = (1.1 * (double)(brect[1] - brect[7]) + 0.5) * GD_OVERSAMPLE;
	    png_state.baseline_offset = -(brect[7] + brect[1]) / 2.0 * GD_OVERSAMPLE;
	}
    }
#endif

    return TRUE;
}

TERM_PUBLIC void
PNG_pointsize(double ptsize)
{
    if (ptsize < 0)
	ptsize = 1;
    PNG_ps = (int)(((double)PNG_POINT_SCALE * ptsize) + 0.5);
}

/*
 * Ethan A Merritt November 2003
 *	- Support for enhanced text mode
 * BUGS:
 *	- placement of overprinted characters is not correct;
 *	  the overprinted text (pass 2) should be centered, not left-justified
 * PROBLEMS:
 *	- the Symbol font encoding didn't work in libgd until 2.0.21
 * 	- Placement of superscripts and subscripts relies on information
 * 	  in the font description that is not always reliable
 *	- the TTF character encoding for non-keyboard characters does
 *	  not always match the PostScript standard.
 *	- Spacing of rotated text is incorrect; I believe this is a due
 *	  to a problem in the text rotation code (aspect ratio??).
 */

static TBOOLEAN ENHgd_opened_string;

/* used in determining height of processed text */
static float ENHgd_base;

/* use these so that we don't over-write the current font settings in png_state */
static double  ENHgd_fontsize;
static char   *ENHgd_font;

static int ENHgd_overprint = 0;
static TBOOLEAN ENHgd_widthflag = TRUE;
static unsigned int ENHgd_xsave, ENHgd_ysave;

TERM_PUBLIC void
ENHGD_OPEN(
    char *fontname,
    double fontsize, double base,
    TBOOLEAN widthflag,
    TBOOLEAN showflag,
    int overprint)
{
    /* If the overprint code requests a save or restore, that's all we do */
    if (overprint == 3) {
	ENHgd_xsave = png_state.x;
	ENHgd_ysave = png_state.y;
	return;
    } else if (overprint == 4) {
	PNG_move(ENHgd_xsave, ENHgd_ysave);
	return;
    }

    if (!ENHgd_opened_string) {
	ENHgd_opened_string = TRUE;
	enhanced_cur_text = &enhanced_text[0];
	ENHgd_font = fontname;
	ENHgd_fontsize = fontsize;
	ENHgd_base = base;
	ENHgd_show = showflag;
	ENHgd_overprint = overprint;
	ENHgd_widthflag = widthflag;
    }
}

/* Write a string fragment and update the current position */
TERM_PUBLIC void
ENHGD_FLUSH()
{
    int brect[8]; char *err;
    unsigned int x, y;
    int px, py;  /* pixel coordinates for gd calls */
    char *fragment = enhanced_text;

    if (!ENHgd_opened_string)
	return;

    ENHgd_opened_string = FALSE;
    *enhanced_cur_text = '\0';

    /* Mar 2011 - added to handle SJIS/UTF8 conversion */
    if (contains8bit(fragment)) {
	gd_iconv(&fragment);
    }

    /* Compute position in inflated coords with baseline offsets.
     * ENHgd_base is in pixel-point scale (from enhanced_recursion)
     * so we must scale it to inflated coords before using as offset. */
    x = png_state.x;
    y = png_state.y;
    x -= sin(png_state.angle * M_PI_2/90.) * ENHgd_base * GD_OVERSAMPLE;
    y += cos(png_state.angle * M_PI_2/90.) * ENHgd_base * GD_OVERSAMPLE;
    x += sin(png_state.angle * M_PI_2/90.) * png_state.baseline_offset;
    y -= cos(png_state.angle * M_PI_2/90.) * png_state.baseline_offset;

    /* Convert to pixel coords for gd text rendering */
    px = GD_PX(x);
    py = GD_Y(y);

    /* First try the old GDFONTPATH mechanism for locating fonts */
    (void)gdUseFontConfig(0);
#if GD_MIN_VERSION(2,0,36)
    /* libgd defaults to UTF-8 encodings. We have limited options for	*/
    /* over-riding this, but we can try					*/
    if (encoding != S_ENC_UTF8 && ENHgd_font && !strcmp(ENHgd_font,"Symbol")) {
	PNG_FONT_INFO.flags |= gdFTEX_CHARMAP;
	PNG_FONT_INFO.charmap = gdFTEX_Adobe_Custom;
    } else {
	PNG_FONT_INFO.flags &= ~gdFTEX_CHARMAP;
	PNG_FONT_INFO.charmap = 0;   /* gdFTEX_Adobe_Custom */
    }
    err = gdImageStringFTEx(
		(ENHgd_show && !ENHgd_sizeonly) ? png_state.image : NULL,
		brect, png_state.color,
		ENHgd_font, ENHgd_fontsize,
		png_state.angle * M_PI_2/90.,
		px, py, fragment, &PNG_FONT_INFO);
    if (err && gdUseFontConfig(1)) {
	err = gdImageStringFTEx(
		(ENHgd_show && !ENHgd_sizeonly) ? png_state.image : NULL,
		brect, png_state.color,
		ENHgd_font, ENHgd_fontsize,
		png_state.angle * M_PI_2/90.,
		px, py, fragment, &PNG_FONT_INFO);
    }
#else
    err = gdImageStringFT(
		(ENHgd_show && !ENHgd_sizeonly) ? png_state.image : NULL,
		brect, png_state.color,
		ENHgd_font, ENHgd_fontsize,
		png_state.angle * M_PI_2/90.,
		px, py, fragment);
    if (err && gdUseFontConfig(1)) {
	err = gdImageStringFT(
		(ENHgd_show && !ENHgd_sizeonly) ? png_state.image : NULL,
		brect, png_state.color,
		ENHgd_font, ENHgd_fontsize,
		png_state.angle * M_PI_2/90.,
		px, py, fragment);
    }
#endif
    if (err)
	fprintf(stderr,"gdImageStringFT: %s while printing string %s with font %s\n",
	    err,enhanced_text,ENHgd_font);

    if (!ENHgd_sizeonly) {
	int xmax = GPMAX(brect[2],brect[6]);
	int xmin = GPMIN(brect[0],brect[4]);
	int ymax = GPMIN(brect[1],brect[3]);
	int ymin = GPMAX(brect[5],brect[7]);
	if (xmin < bounding_box[0]) bounding_box[0] = xmin;
	if (xmax > bounding_box[2]) bounding_box[2] = xmax;
	if (ymin < bounding_box[1]) bounding_box[1] = ymin;
	if (ymax > bounding_box[3]) bounding_box[3] = ymax;
    }

    /* brect values are in pixel space; scale back to inflated for cursor advance */
    if (ENHgd_overprint == 1) {
	png_state.x += ((brect[2] - brect[0]))/2 * GD_OVERSAMPLE;
	png_state.y -= (brect[3] - brect[1]) * GD_OVERSAMPLE;
    } else if (ENHgd_widthflag) {
	png_state.x += (brect[2] - brect[0]) * GD_OVERSAMPLE;
	png_state.y -= (brect[3] - brect[1]) * GD_OVERSAMPLE;
    }
}

TERM_PUBLIC void
ENHGD_put_text(unsigned int x, unsigned int y, const char *str)
{
    char *original_string = (char *)str;
    char *fontcopy;

    if (ignore_enhanced_text || !png_state.ttffont) {
	PNG_put_text(x,y,str);
	return;
    }

    if (!strlen(str))
	return;

    /* if there are no magic characters, we should just be able
     * punt the string to PNG_put_text()
     */
    if (!strpbrk(str, "{}^_@&~") && !contains_unicode(str)) {
	PNG_put_text(x,y,str);
	return;
    }

    PNG_move(x,y);

    /* set up the global variables needed by enhanced_recursion() */
    enhanced_fontscale = png_state.fontscale;
    safe_strncpy(enhanced_escape_format,"&#x%2.2x;",sizeof(enhanced_escape_format));

    ENHgd_opened_string = FALSE;
    ENHgd_show = TRUE;
    ENHgd_overprint = 0;

    /* EAM - post.trm wasn't doing this, but how else do they get initialized? */
	ENHgd_font = png_state.ttffont;
	ENHgd_fontsize = png_state.ttfsize;

    /* EAM - Software text justification requires two passes */
    if (png_state.justify == RIGHT || png_state.justify == CENTRE)
	ENHgd_sizeonly = TRUE;

    /* Set the recursion going. We say to keep going until a
     * closing brace, but we don't really expect to find one.
     * If the return value is not the nul-terminator of the
     * string, that can only mean that we did find an unmatched
     * closing brace in the string. We increment past it (else
     * we get stuck in an infinite loop) and try again.
     */
    fontcopy = strdup(ENHgd_font);
    while (*(str = enhanced_recursion((char *)str, TRUE,
			fontcopy, ENHgd_fontsize * png_state.fontscale,
			0.0, TRUE, TRUE, 0))) {
	(term->enhanced_flush)();

	/* I think we can only get here if *str == '}' */
	    enh_err_check(str);

	if (!*++str)
	    break; /* end of string */

	/* else carry on and process the rest of the string */
    }
    free(fontcopy);

    /* We can do text justification by running the entire top level string */
    /* through 2 times, with the ENHgd_sizeonly flag set the first time.   */
    /* After seeing where the final position is, we then offset the start  */
    /* point accordingly and run it again without the flag set.            */
    if (png_state.justify == RIGHT || png_state.justify == CENTRE) {
	int justification = png_state.justify;
	int x_offset = png_state.x - x;
	int y_offset = 0;

	if (png_state.angle != 0)
	    y_offset = png_state.y - y;
	png_state.justify = LEFT;
	ENHgd_sizeonly = FALSE;

	if (justification == RIGHT) {
	    ENHGD_put_text(x - x_offset, y - y_offset, original_string);
	} else if (justification == CENTRE) {
	    ENHGD_put_text(x - x_offset/2, y - y_offset/2, original_string);
	}
	png_state.justify = justification;
    }

}

TERM_PUBLIC void
ENHGD_boxed_text(unsigned int x, unsigned int y, int option)
{
    switch (option) {
    case TEXTBOX_INIT:
	/* Initialize bounding box for this text string (pixel coords) */
	bounding_box[0] = bounding_box[2] = GD_PX(x);
	bounding_box[1] = bounding_box[3] = GD_Y(y);
	break;
    case TEXTBOX_OUTLINE:
	/* Stroke the outline of the bounding box for previous text.
	 * bounding_box is in pixel coords; PNG_move/PNG_vector expect
	 * inflated terminal coords, so convert back.
	 */
	{
	    int bx0 = bounding_box[0] - bounding_xmargin;
	    int bx1 = bounding_box[2] + bounding_xmargin;
	    int by0 = bounding_box[1] - bounding_ymargin;
	    int by1 = bounding_box[3] + bounding_ymargin;
	    /* Convert pixel coords to inflated terminal coords.
	     * For X: inflated = pixel * GD_OVERSAMPLE
	     * For Y: inflated = png_state.height - pixel * GD_OVERSAMPLE
	     *   (since GD_Y(inflated) = (height - inflated) / GD_OVERSAMPLE)
	     */
	    unsigned int ix0 = GD_TERM(bx0);
	    unsigned int ix1 = GD_TERM(bx1);
	    unsigned int iy0 = png_state.height - GD_TERM(by0);
	    unsigned int iy1 = png_state.height - GD_TERM(by1);
	    PNG_move  (ix0, iy0);
	    PNG_vector(ix0, iy1);
	    PNG_vector(ix1, iy1);
	    PNG_vector(ix1, iy0);
	    PNG_vector(ix0, iy0);
	}
	break;
    case TEXTBOX_BACKGROUNDFILL:
	/* Fill the box with current color (pixel coords). */
	gdImageFilledRectangle(png_state.image,
		bounding_box[0] - bounding_xmargin,
		bounding_box[1] - bounding_ymargin,
		bounding_box[2] + bounding_xmargin,
		bounding_box[3] + bounding_ymargin,
		png_state.color);
	break;
    case TEXTBOX_MARGINS:
	/* Change the text margins (in pixels) */
	bounding_xmargin = GD_TEXTBOX_MARGIN * (double)x / 100.;
	bounding_ymargin = GD_TEXTBOX_MARGIN * (double)y / 100.;
	break;
    default:
    	break;
    }
}



#undef gdfont

TERM_PUBLIC void
PNG_image (unsigned int M, unsigned int N, coordval * image, gpiPoint * corner, t_imagecolor color_mode)
{
    int m, n, mout, nout;
    int x1,y1,x2,y2;
    int xclip1, xclip2, yclip1, yclip2;
    int pixel;
    gdImagePtr im;

    if (png_state.TrueColor) {
	im = gdImageCreateTrueColor(M, N);
	if (!im)
	    int_error(NO_CARET,"libgd: failed to create image structure");
    } else {
	im = gdImageCreate(M, N);
	if (!im)
	    int_error(NO_CARET,"libgd: failed to create image structure");
	gdImagePaletteCopy(im, png_state.image);
    }

    /* Set clipping bound for area into which we will copy (pixel coords) */
    xclip1 = GPMIN(GD_PX(corner[2].x), GD_PX(corner[3].x));
    xclip2 = GPMAX(GD_PX(corner[2].x), GD_PX(corner[3].x));
    yclip1 = GPMIN(GD_Y(corner[2].y), GD_Y(corner[3].y));
    yclip2 = GPMAX(GD_Y(corner[2].y), GD_Y(corner[3].y));
    gdImageGetClip(png_state.image, &x1, &y1, &x2, &y2);
    gdImageSetClip(png_state.image, xclip1, yclip1, xclip2, yclip2);

    /* Initialize image area with current contents of plot (pixel sizes). */
    mout = abs( GD_PX(corner[1].x) - GD_PX(corner[0].x) );
    nout = abs( GD_Y(corner[1].y) - GD_Y(corner[0].y) );

    if (color_mode == IC_RGBA) {
	/* RGB + Alpha channel
	 * Resize explicitly in a loop rather than calling a library
	 * routine in order not to apply the alpha correction more than
	 * once when building up any given output pixel.
	 */
	int px0 = GD_PX(corner[0].x);
	int py0 = GD_Y(corner[0].y);
	for (n=0; n<nout; n++) {
	for (m=0; m<mout; m++) {
	    rgb_color rgb1;
	    rgb255_color rgb255;
	    int alpha;
	    int msrc = (m*(long)(M-1))/(mout-1);
	    int nsrc = (n*(long)(N-1))/(nout-1);
	    coordval *cval = image + 4*(M*nsrc + msrc);
	    rgb1.r = *cval++;
	    rgb1.g = *cval++;
	    rgb1.b = *cval++;
	    alpha  = *cval++;
	    alpha  = 127 - (alpha>>1);	/* input is [0:255] but gd wants [127:0] */
	    rgb255_from_rgb1( rgb1, &rgb255 );
	    pixel = gdImageColorResolveAlpha( png_state.image,
		(int)rgb255.r, (int)rgb255.g, (int)rgb255.b, alpha);
	    gdImageSetPixel( png_state.image, m + px0, n + py0, pixel );
	}
	}

    } else if (color_mode == IC_RGB) {
	/* TrueColor 24-bit color mode */
	for (n=0; n<N; n++) {
	for (m=0; m<M; m++) {
	    rgb_color rgb1;
	    rgb255_color rgb255;
	    rgb1.r = *image++;
	    rgb1.g = *image++;
	    rgb1.b = *image++;
	    rgb255_from_rgb1( rgb1, &rgb255 );
	    pixel = gdImageColorResolve( im,
		(int)rgb255.r, (int)rgb255.g, (int)rgb255.b );
	    gdImageSetPixel( im, m, n, pixel );
	}
	}

    } else if (color_mode == IC_PALETTE) {
	/* Palette color lookup from gray value */
	for (n=0; n<N; n++) {
	for (m=0; m<M; m++) {
	    rgb255_color rgb;
	    if (isnan(*image)) {
		/* Transparent would be even better */
		pixel = png_state.color_table[0];
		image++;
	    } else {
		rgb255maxcolors_from_gray( *image++, &rgb );
		pixel = gdImageColorResolve( im,
		    (int)rgb.r, (int)rgb.g, (int)rgb.b );
	    }
	    gdImageSetPixel( im, m, n, pixel );
	}
	}
    }

    /* Copy and resize onto requested region of plot */
    if (color_mode != IC_RGBA)
	gdImageCopyResized(png_state.image, im,
		GD_PX(corner[0].x), GD_Y(corner[0].y),	/* Destination X, Y */
		0, 0, 				/* Source X, Y */
		mout, nout,			/* Destination Width, Height */
		M, N				/* Source Width, Height */
		);
    gdImageDestroy(im);

    /* Restore previous clipping, if any */
    gdImageSetClip(png_state.image, x1, y1, x2, y2);
}


/* Mar 2011 - shige takeno
 * libgd can be built to prefer UTF-8 or SJIS encoding for Japanese.
 * If it wants SJIS and we are currently in UTF8, convert.
 * If it wants UTF8 and we are currently in SJIS, convert.
 */
static void
gd_iconv(char **string)
{
#ifdef HAVE_ICONV
    size_t len1 = strlen(*string)+1;
    size_t len2;
    iconv_t cd;
    char *stmp;

    /* We will return this to the caller and free it next time */
    static char *iconv_string = NULL;
    free(iconv_string);
    iconv_string = NULL;

#ifdef JIS_GDLIB
    if (encoding == S_ENC_UTF8) { /* UTF-8 -> Shift_JIS by iconv */
	len2 = len1;
	iconv_string = gp_alloc(len2, "iconv string");
	stmp = iconv_string;
	if ((cd = iconv_open("Shift_JIS", "UTF-8")) == (iconv_t)-1)
	  int_warn(NO_CARET, "iconv_open failed");
	else {
	    if (iconv(cd, (void *)string, &len1, &stmp, &len2) == (size_t)-1)
		int_warn(NO_CARET, "iconv failed");
	    else
		*string = iconv_string;
	    iconv_close(cd);
	}
    }
#else /* ! JIS_GDLIB */
    if (encoding == S_ENC_SJIS) { /* Shift_JIS -> UTF-8 by iconv */
	len2 = len1*3/2+2;
	iconv_string = gp_alloc(len2, "iconv string");
	stmp = iconv_string;
	if ((cd = iconv_open("UTF-8", "Shift_JIS")) == (iconv_t)-1)
	  int_warn(NO_CARET, "iconv_open failed");
	else {
	    if (iconv(cd, (void *)string, &len1, &stmp, &len2) == (size_t)-1)
		int_warn(NO_CARET, "iconv failed");
	    else
		*string = iconv_string;
	    iconv_close(cd);
	}
    }
#endif /* JIS_GDLIB */
    if (encoding == S_ENC_EUCJP) { /* EUC-JP -> UTF-8 by iconv */
	len2 = len1*3/2+2;
	iconv_string = gp_alloc(len2, "iconv string");
	stmp = iconv_string;
	if ((cd = iconv_open("UTF-8", "EUC-JP")) == (iconv_t)-1)
	  int_warn(NO_CARET, "iconv_open failed");
	else {
	    if (iconv(cd, (void *)string, &len1, &stmp, &len2) == (size_t)-1)
		int_warn(NO_CARET, "iconv failed");
	    else
		*string = iconv_string;
	    iconv_close(cd);
	}
    }
#else /* ! HAVE_ICONV */
#ifdef JIS_GDLIB
    if (encoding == S_ENC_UTF8)
	int_warn(NO_CARET,
		 "This gdlib supports Shift_JIS encoding, but not UTF-8.");
#else /* ! JIS_GDLIB */
    if (encoding == S_ENC_SJIS) /* Shift_JIS -> UTF-8 */
	int_warn(NO_CARET,
		 "This gdlib supports UTF-8 encoding, but not Shift_JIS.");
#endif  /* JIS_GDLIB */
#endif /* HAVE_ICONV */
}

/*
 * PNG_layer - Handle per-curve key sample clipping.
 * Plot-area clipping enable/disable is now handled by PNG_clip_state().
 * BEGIN_KEYSAMPLE / END_KEYSAMPLE suspend/restore the driver's internal
 * clip state using values already stored by PNG_clip_state().
 */
TERM_PUBLIC void
PNG_layer(t_termlayer layer)
{
    switch (layer) {
    case TERM_LAYER_BEGIN_KEYSAMPLE:
	/* Key samples may be drawn outside the plot area (e.g. key lmargin,
	 * key outside, key under).  Temporarily restore the saved full-image
	 * clip so that the sample line and filled rectangle are not clipped
	 * away by the per-curve plot-area clip enabled by PNG_clip_state().
	 * Flush any deferred endcap and composite any pending alpha layer
	 * first, using the current per-curve plot-area clip and transparency
	 * context, before switching to the full-image clip.
	 */
	if (PNG_plot_clip_active) {
	    PNG_flush_pending_endcap();
	    if (png_state.alpha_layer_active)
		PNG_alpha_layer_composite();
	    gdImageSetClip(png_state.image,
			    PNG_saved_clip_x1, PNG_saved_clip_y1,
			    PNG_saved_clip_x2, PNG_saved_clip_y2);
	}
	break;
    case TERM_LAYER_END_KEYSAMPLE:
	/* Restore the per-curve plot-area clip captured from the bbox
	 * argument to PNG_clip_state().  PNG_layer() only swaps between
	 * gd-local clip rectangles while key samples are drawn.
	 * Flush any deferred endcap and composite any key-sample alpha
	 * layer content first, under the full-image clip and current
	 * transparency context, before switching back to the plot-area clip.
	 */
	if (PNG_plot_clip_active) {
	    PNG_flush_pending_endcap();
	    if (png_state.alpha_layer_active)
		PNG_alpha_layer_composite();
	    gdImageSetClip(png_state.image,
			    PNG_plot_clip_x1, PNG_plot_clip_y1,
			    PNG_plot_clip_x2, PNG_plot_clip_y2);
	}
	break;
    default:
	break;
    }
}

/*
 * PNG_clip_state - Enable/disable terminal-level plot-area clipping.
 * Non-NULL bbox calls bracket curve drawing; NULL bbox calls may also
 * be issued as idempotent cleanup from reset or plot shutdown paths.
 * bbox != NULL: enable clipping to this bounding box.
 * bbox == NULL: disable clipping (restore full-canvas drawing).
 */
TERM_PUBLIC void
PNG_clip_state(struct BoundingBox *bbox, int state)
{
    (void) state;  /* reserved for future use */

    if (bbox && !PNG_plot_clip_active) {
	PNG_flush_pending_endcap();
	if (png_state.alpha_layer_active)
	    PNG_alpha_layer_composite();

	/* Save current full-image clip and apply plot-area clip */
	gdImageGetClip(png_state.image,
	    &PNG_saved_clip_x1, &PNG_saved_clip_y1,
	    &PNG_saved_clip_x2, &PNG_saved_clip_y2);
	PNG_plot_clip_x1 = GD_PX(bbox->xleft);
	PNG_plot_clip_y1 = GD_Y(bbox->ytop);
	PNG_plot_clip_x2 = GD_PX(bbox->xright);
	PNG_plot_clip_y2 = GD_Y(bbox->ybot);
	gdImageSetClip(png_state.image,
	    PNG_plot_clip_x1, PNG_plot_clip_y1,
	    PNG_plot_clip_x2, PNG_plot_clip_y2);
	PNG_plot_clip_active = TRUE;
    } else if (!bbox && PNG_plot_clip_active) {
	/* Disable: flush pending drawing ops, then restore full-image clip */
	PNG_flush_pending_endcap();
	if (png_state.alpha_layer_active)
	    PNG_alpha_layer_composite();
	gdImageSetClip(png_state.image,
	    PNG_saved_clip_x1, PNG_saved_clip_y1,
	    PNG_saved_clip_x2, PNG_saved_clip_y2);
	PNG_plot_clip_active = FALSE;
    }
}

/*
 * PNG_path - Handle newpath/closepath for proper closed-path corners.
 * On closepath, flush the deferred endcap and draw a join disc at the
 * closing corner so that the junction between the last and first
 * segments is rendered as a line join rather than two butt caps.
 */
TERM_PUBLIC void
PNG_path(int p)
{
    switch (p) {
    case 0: /* newpath */
	PNG_path_is_open = TRUE;
	PNG_path_start_x = 0.0;
	PNG_path_start_y = 0.0;
	PNG_path_first_dx = 0.0;
	PNG_path_first_dy = 0.0;
	break;
    case 1: /* closepath */
	if (PNG_path_is_open
	&&  (PNG_path_first_dx != 0.0 || PNG_path_first_dy != 0.0)) {
	    double half_w = (double)png_state.linewidth / 2.0;
	    double prev_len, first_len;

	    /* Flush the deferred endcap from the last segment */
	    PNG_flush_pending_endcap();
	    if (png_state.alpha_layer_active)
		PNG_alpha_layer_composite();

	    /* Normalize the direction vectors (they are raw pixel deltas) */
	    prev_len = sqrt(PNG_prev_dash_dx*PNG_prev_dash_dx
			  + PNG_prev_dash_dy*PNG_prev_dash_dy);
	    first_len = sqrt(PNG_path_first_dx*PNG_path_first_dx
			   + PNG_path_first_dy*PNG_path_first_dy);

	    if (prev_len > 0.0 && first_len > 0.0) {
		/* Draw a join disc connecting last->first segment */
		PNG_draw_join_disc(
		    PNG_path_start_x, PNG_path_start_y, half_w,
		    PNG_prev_dash_dx / prev_len,
		    PNG_prev_dash_dy / prev_len,
		    PNG_path_first_dx / first_len,
		    PNG_path_first_dy / first_len,
		    png_state.color);
	    }
	}
	PNG_path_is_open = FALSE;
	break;
    }
}

