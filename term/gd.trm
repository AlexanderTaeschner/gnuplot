#define Y(y) (png_state.height - (y))

/* Coordinate conversion macros.
 * Inflation of term->xmax/ymax by GD_OVERSAMPLE while gdImage is kept
 * at actual pixel size.
 * All drawing functions convert inflated coords to pixel coords via 
 * GD_PX()/GD_Y() before calling libgd. png_state.height is in inflated units;
 * Y() works in inflated space, GD_Y()/GD_YF() combine Y-flip and downscale in one step.
 * Text, points, fills, polygons, and images all convert at the boundary. */

/* Convert inflated terminal coordinate to pixel coordinate (integer) */
#define GD_PX(c)  ((int)(((int)c) / (double)GD_OVERSAMPLE + 0.5))

/* Convert inflated terminal coordinate to pixel coordinate (float) */
#define GD_PXF(c) ((double)((int)c) / (double)GD_OVERSAMPLE)

/* Convert pixel coordinate to inflated terminal coordinate */
#define GD_TERM(p) ((int)(((int)p) * GD_OVERSAMPLE))

/* Y-flip in pixel space: converts inflated Y to pixel Y */
#define GD_Y(y) ((int)(((double)png_state.height - (double)((int)y)) / GD_OVERSAMPLE + 0.5))

/* Y-flip to pixel float */
#define GD_YF(y) (((double)png_state.height - (double)((int)y)) / GD_OVERSAMPLE)

