    TBOOLEAN  anchor;		/* sixel and kitty treat it as synonym for "anchor" */
    int       loop_count;	/* Number of times to repeat sequence */
    int       frame_count;	/* Number of frames in animation */
    int       frame_delay;	/* Time between frames in .01 seconds */
    gdImagePtr previous_image;	/* Needed to encode animation as a series of deltas */
    /* Alpha layer for overlap-free semi-transparent line rendering */
    gdImagePtr alpha_layer;	/* offscreen buffer (NULL when not allocated) */
    gdImagePtr alpha_main_image;	/* saved main image while alpha_layer is active */
    TBOOLEAN   alpha_layer_active;	/* TRUE when rendering to offscreen buffer */
    int        alpha_line_gd_alpha;	/* line's libgd alpha (0=opaque, 127=transparent) */
    int        alpha_opaque_color;	/* line color with alpha stripped to opaque */
    int        alpha_dirty_x1, alpha_dirty_y1;	/* dirty rect min */
    int        alpha_dirty_x2, alpha_dirty_y2;	/* dirty rect max */
} png_state
= {.anchor = TRUE};

