/* Coordinate-space oversampling factor (similar to pngcairo's GP_CAIRO_SCALE).
 * Defined here, before driver.h, so the constant is visible in both the
 * TERM_PROTO section (TERM_TABLE initializers, default char/tic sizes) and
 * the TERM_BODY section (conversion macros, drawing functions). */
#define GD_OVERSAMPLE 20

