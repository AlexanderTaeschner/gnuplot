/* Built-in dash patterns matching the cairo terminal.
 * Alternating dash/gap lengths, 0-terminated.
 * Scaled by linewidth * dashlength_factor at draw time.
 */
#define PNG_NUM_DASHTYPES 5
static float PNG_dashpatterns[PNG_NUM_DASHTYPES][8] = {
    { 0.0 },						/* solid (placeholder) */
    { 5.0, 8.0, 5.0, 8.0, 0.0, 0.0, 0.0, 0.0 },	/* medium dashes */
    { 1.0, 4.0, 1.0, 4.0, 0.0, 0.0, 0.0, 0.0 },	/* dots */
    { 8.0, 4.0, 2.0, 4.0, 0.0, 0.0, 0.0, 0.0 },	/* dash dot */
    { 9.0, 4.0, 1.0, 4.0, 1.0, 4.0, 0.0, 0.0 },	/* dash dot dot */
};

/* Current position in the dash pattern cycle (scaled units). */
static double PNG_dash_pos = 0.0;

/* Previous segment direction in pixel space (for join disc logic) */
static double PNG_prev_seg_dx = 0.0;
static double PNG_prev_seg_dy = 0.0;

/* Previous sub-segment direction within dash walker (pixel space) */
static double PNG_prev_dash_dx = 0.0;
static double PNG_prev_dash_dy = 0.0;

/* Closed-path state for join disc at the closing corner.
 * newpath marks the path as open and clears the saved state; the
 * first PNG_vector() call records the start position and the first
 * segment's direction; closepath draws a join disc between the last
 * and first segments.
 */
static TBOOLEAN PNG_path_is_open = FALSE;
static double PNG_path_start_x = 0.0;
static double PNG_path_start_y = 0.0;
static double PNG_path_first_dx = 0.0;
static double PNG_path_first_dy = 0.0;

/* Endcap types for PNG_draw_aa_thick_line() */
enum {
    PNG_CAP_HARD   = 0,	/* Hard clip at cap plane; for internal polyline joints */
    PNG_CAP_BUTT   = 1,	/* AA ramp at cap plane */
    PNG_CAP_ROUND  = 2,	/* Semicircular cap */
    PNG_CAP_SQUARE = 3	/* Extend halfw past endpoint, then AA ramp */
};

/* Deferred endcap state.  When a polyline path ends mid-dash,
 * the proper endcap is drawn at the next PNG_move() or PNG_text().
 */
static struct {
    int active;
    double ex, ey;		/* endpoint position (screen coords) */
    double ux, uy;		/* unit direction at endpoint */
    int thick;
    int color;
} PNG_pending_endcap;

/* Saved clip region that was active before PNG_clip_state(bbox, 0)
 * enabled per-curve plot-area clipping.  PNG_clip_state(NULL, 0)
 * restores it after curve drawing, while PNG_layer() temporarily
 * suspends/restores the active plot clip around key samples.
 */
static int  PNG_saved_clip_x1, PNG_saved_clip_y1;
static int  PNG_saved_clip_x2, PNG_saved_clip_y2;
static TBOOLEAN PNG_plot_clip_active = FALSE;

/* Plot-area clip rectangle in pixel coordinates, computed by
 * PNG_clip_state() from its bbox argument.  Stored separately so
 * PNG_layer() can suspend/restore the same plot clip around key
 * samples without consulting core clip_area state.
 */
static int  PNG_plot_clip_x1, PNG_plot_clip_y1;
static int  PNG_plot_clip_x2, PNG_plot_clip_y2;

